{
  "command_eng": "When the contact sensor is detected, turn on the light.",
  "connected_devices": {
    "Entrance_Contact": {
      "category": [
        "ContactSensor"
      ],
      "tags": [
        "Entrance",
        "ContactSensor"
      ]
    },
    "LivingRoom_Light": {
      "category": [
        "Light",
        "Switch",
        "ColorControl",
        "LevelControl"
      ],
      "tags": [
        "LivingRoom",
        "Light",
        "Switch"
      ]
    },
    "Kitchen_Light": {
      "category": [
        "Light",
        "Switch",
        "ColorControl",
        "LevelControl"
      ],
      "tags": [
        "Kitchen",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "ContactSensor.Contact == true",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Switch.On",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#ContactSensor).contactSensor_contact == true)\n(#Light).switch_on()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#ContactSensor).contactSensor_contact == true)\n(#Light).switch_on()\"\n}"
}