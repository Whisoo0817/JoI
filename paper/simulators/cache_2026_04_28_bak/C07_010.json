{
  "command_eng": "When a leak is detected, close the valve.",
  "connected_devices": {
    "Kitchen_LeakSensor": {
      "category": [
        "LeakSensor"
      ],
      "tags": [
        "Kitchen",
        "LeakSensor"
      ]
    },
    "Bathroom_LeakSensor": {
      "category": [
        "LeakSensor"
      ],
      "tags": [
        "Bathroom",
        "LeakSensor"
      ]
    },
    "Kitchen_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Kitchen",
        "Valve"
      ]
    },
    "Bathroom_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Bathroom",
        "Valve"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "LeakSensor.Leakage == true",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Valve.Close",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#LeakSensor).leakSensor_leakage == true)\n(#Valve).valve_close()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#LeakSensor).leakSensor_leakage == true)\n(#Valve).valve_close()\"\n}"
}