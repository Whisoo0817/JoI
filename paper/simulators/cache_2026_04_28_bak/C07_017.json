{
  "command_eng": "When a water leak is detected in the basement, sound the main siren in emergency mode.",
  "connected_devices": {
    "Basement_Leak": {
      "category": [
        "LeakSensor"
      ],
      "tags": [
        "Basement",
        "LeakSensor"
      ]
    },
    "Outdoor_Leak": {
      "category": [
        "LeakSensor"
      ],
      "tags": [
        "Outdoor",
        "LeakSensor"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    },
    "Entrance_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "Entrance",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "LeakSensor.Leakage == true",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Siren.SetSirenMode",
        "args": {
          "Mode": "emergency"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#Basement #LeakSensor).leakSensor_leakage == true)\n(#Main #Siren).siren_setSirenMode(\"emergency\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#Basement #LeakSensor).leakSensor_leakage == true)\n(#Main #Siren).siren_setSirenMode(\\\"emergency\\\")\"\n}"
}