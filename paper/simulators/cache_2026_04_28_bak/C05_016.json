{
  "command_eng": "If a person is detected and smoke is detected, sound the siren in fire mode and announce \"Evacuate\" through the speaker.",
  "connected_devices": {
    "Living_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Living",
        "PresenceSensor"
      ]
    },
    "Bedroom_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Bedroom",
        "PresenceSensor"
      ]
    },
    "Kitchen_Smoke": {
      "category": [
        "SmokeDetector"
      ],
      "tags": [
        "Kitchen",
        "SmokeDetector"
      ]
    },
    "Bedroom_Smoke": {
      "category": [
        "SmokeDetector"
      ],
      "tags": [
        "Bedroom",
        "SmokeDetector"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    },
    "Entrance_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Entrance",
        "Siren"
      ]
    },
    "Living_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Living",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "PresenceSensor.Presence == true && SmokeDetector.Smoke == true",
        "then": [
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "fire"
            }
          },
          {
            "op": "call",
            "target": "Speaker.Speak",
            "args": {
              "Text": "Evacuate"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if (all(#SmokeDetector).smokeDetector_smoke ==| true && any(#PresenceSensor).presenceSensor_presence == true) {\n(#Siren).siren_setSirenMode(\"fire\")\n(#Speaker).speaker_speak(\"Evacuate\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if (all(#SmokeDetector).smokeDetector_smoke ==| true && any(#PresenceSensor).presenceSensor_presence == true) {\n(#Siren).siren_setSirenMode(\\\"fire\\\")\\n(#Speaker).speaker_speak(\\\"Evacuate\\\")\\n}\"\n}"
}