{
  "command_eng": "If the carbon dioxide is 1500ppm or higher and the blind is closed, set the air purifier to auto and raise the blind.",
  "connected_devices": {
    "Living_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Living",
        "AirQualitySensor"
      ]
    },
    "Bedroom_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Bedroom",
        "AirQualitySensor"
      ]
    },
    "Living_Blind": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Living",
        "Blind",
        "WindowCovering"
      ]
    },
    "Bedroom_Blind": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Bedroom",
        "Blind",
        "WindowCovering"
      ]
    },
    "Living_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Living",
        "AirPurifier"
      ]
    },
    "Bedroom_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Bedroom",
        "AirPurifier"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "AirQualitySensor.CarbonDioxide >= 1500 && WindowCovering.CurrentPosition == 100",
        "then": [
          {
            "op": "call",
            "target": "AirPurifier.SetAirPurifierMode",
            "args": {
              "Mode": "auto"
            }
          },
          {
            "op": "call",
            "target": "WindowCovering.UpOrOpen",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#AirQualitySensor).airQualitySensor_carbonDioxide >= 1500 and (#WindowCovering).windowCovering_currentPosition == 100) {\n(#AirPurifier).airPurifier_setAirPurifierMode(\"auto\")\n(#WindowCovering).windowCovering_upOrOpen()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#AirQualitySensor).airQualitySensor_carbonDioxide >= 1500 and (#WindowCovering).windowCovering_currentPosition == 100) {\n(#AirPurifier).airPurifier_setAirPurifierMode(\\\"auto\\\")\\n(#WindowCovering).windowCovering_upOrOpen()\\n}\"\n}"
}