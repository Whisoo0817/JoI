{
  "command_eng": "If any indoor Group1 humidity sensor reads 60% or higher, set all indoor Group1 dehumidifiers to drying mode.",
  "connected_devices": {
    "In_G1_Hum_1": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Indoor",
        "Group1",
        "HumiditySensor"
      ]
    },
    "In_G1_Hum_2": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Indoor",
        "Group1",
        "HumiditySensor"
      ]
    },
    "Out_G1_Hum": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Outdoor",
        "Group1",
        "HumiditySensor"
      ]
    },
    "In_G2_Hum": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Indoor",
        "Group2",
        "HumiditySensor"
      ]
    },
    "In_G1_Dehum_1": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "Indoor",
        "Group1",
        "Dehumidifier"
      ]
    },
    "In_G1_Dehum_2": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "Indoor",
        "Group1",
        "Dehumidifier"
      ]
    },
    "Out_G1_Dehum": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "Outdoor",
        "Group1",
        "Dehumidifier"
      ]
    },
    "In_G2_Dehum": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "Indoor",
        "Group2",
        "Dehumidifier"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "HumiditySensor.Humidity >= 60",
        "then": [
          {
            "op": "call",
            "target": "Dehumidifier.SetDehumidifierMode",
            "args": {
              "Mode": "drying"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if (any(#Indoor #Group1 #HumiditySensor).humiditySensor_humidity >= 60) {\nall(#Indoor #Group1 #Dehumidifier).dehumidifier_setDehumidifierMode(\"drying\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if (any(#Indoor #Group1 #HumiditySensor).humiditySensor_humidity >= 60) {\nall(#Indoor #Group1 #Dehumidifier).dehumidifier_setDehumidifierMode(\\\"drying\\\")\\n}\"\n}"
}