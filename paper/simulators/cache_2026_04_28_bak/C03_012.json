{
  "command_eng": "If the speaker volume is 40 or higher, stop the playback.",
  "connected_devices": {
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "Speaker.Volume >= 40",
        "then": [
          {
            "op": "call",
            "target": "Speaker.Stop",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Speaker).speaker_volume >= 40) {\n(#Speaker).speaker_stop()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Speaker).speaker_volume >= 40) {\n(#Speaker).speaker_stop()\n}\"\n}"
}