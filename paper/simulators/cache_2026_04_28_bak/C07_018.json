{
  "command_eng": "When the garage door is opened, take a picture with the garage camera.",
  "connected_devices": {
    "Garage_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Garage",
        "Door"
      ]
    },
    "Front_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Front",
        "Door"
      ]
    },
    "Garage_Camera": {
      "category": [
        "Camera"
      ],
      "tags": [
        "Garage",
        "Camera"
      ]
    },
    "LivingRoom_Camera": {
      "category": [
        "Camera"
      ],
      "tags": [
        "LivingRoom",
        "Camera"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "Door.DoorState == \"open\"",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Camera.CaptureImage",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#Garage #Door).door_doorState == \"open\")\nimg = (#Garage #Camera).camera_captureImage()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#Garage #Door).door_doorState == \\\"open\\\")\\nimg = (#Garage #Camera).camera_captureImage()\"\n}"
}