{
  "command_eng": "If the contact sensor at the entrance is in detected state, sound the emergency siren.",
  "connected_devices": {
    "Entrance_Contact": {
      "category": [
        "ContactSensor"
      ],
      "tags": [
        "Entrance",
        "ContactSensor"
      ]
    },
    "Garage_Contact": {
      "category": [
        "ContactSensor"
      ],
      "tags": [
        "Garage",
        "ContactSensor"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    },
    "Garage_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Garage",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "ContactSensor.Contact == true",
        "then": [
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "emergency"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Entrance #ContactSensor).contactSensor_contact == true) {\n(#Siren).siren_setSirenMode(\"emergency\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Entrance #ContactSensor).contactSensor_contact == true) {\n(#Siren).siren_setSirenMode(\\\"emergency\\\")\\n}\"\n}"
}