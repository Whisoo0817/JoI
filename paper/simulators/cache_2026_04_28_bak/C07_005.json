{
  "command_eng": "When the carbon dioxide concentration reaches 1000ppm or higher, sound the emergency siren.",
  "connected_devices": {
    "LivingRoom_CO2Sensor": {
      "category": [
        "CarbonDioxideSensor"
      ],
      "tags": [
        "LivingRoom",
        "CarbonDioxideSensor"
      ]
    },
    "Bedroom_CO2Sensor": {
      "category": [
        "CarbonDioxideSensor"
      ],
      "tags": [
        "Bedroom",
        "CarbonDioxideSensor"
      ]
    },
    "LivingRoom_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "Siren"
      ]
    },
    "Entrance_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "Entrance",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "CarbonDioxideSensor.CarbonDioxide >= 1000",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Siren.SetSirenMode",
        "args": {
          "Mode": "emergency"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#CarbonDioxideSensor).carbonDioxideSensor_carbonDioxide >= 1000)\n(#Siren).siren_setSirenMode(\"emergency\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#CarbonDioxideSensor).carbonDioxideSensor_carbonDioxide >= 1000)\n(#Siren).siren_setSirenMode(\\\"emergency\\\")\"\n}"
}