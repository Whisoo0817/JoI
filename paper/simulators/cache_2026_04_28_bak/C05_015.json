{
  "command_eng": "If it is raining and the door is open, close the door and set the dehumidifier to internal Care mode.",
  "connected_devices": {
    "Outdoor_Rain": {
      "category": [
        "RainSensor"
      ],
      "tags": [
        "Outdoor",
        "RainSensor"
      ]
    },
    "Garden_Rain": {
      "category": [
        "RainSensor"
      ],
      "tags": [
        "Garden",
        "RainSensor"
      ]
    },
    "Living_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Living",
        "Door"
      ]
    },
    "Bedroom_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Bedroom",
        "Door"
      ]
    },
    "Living_Dehum": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "Living",
        "Dehumidifier"
      ]
    },
    "Bedroom_Dehum": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "Bedroom",
        "Dehumidifier"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "RainSensor.Rain == true && Door.DoorState == \"open\"",
        "then": [
          {
            "op": "call",
            "target": "Door.Close",
            "args": {}
          },
          {
            "op": "call",
            "target": "Dehumidifier.SetDehumidifierMode",
            "args": {
              "Mode": "internalCare"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#RainSensor).rainSensor_rain == true and (#Door).door_doorState == \"open\") {\n(#Door).door_close()\n(#Dehumidifier).dehumidifier_setDehumidifierMode(\"internalCare\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#RainSensor).rainSensor_rain == true and (#Door).door_doorState == \\\"open\\\") {\\n(#Door).door_close()\\n(#Dehumidifier).dehumidifier_setDehumidifierMode(\\\"internalCare\\\")\\n}\"\n}"
}