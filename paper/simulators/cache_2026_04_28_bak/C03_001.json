{
  "command_eng": "Stop charging if the voltage is 220V or higher.",
  "connected_devices": {
    "Garage_Charger": {
      "category": [
        "Charger",
        "Switch"
      ],
      "tags": [
        "Charger",
        "Garage"
      ]
    },
    "Office_Charger": {
      "category": [
        "Charger",
        "Switch"
      ],
      "tags": [
        "Charger",
        "Office"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "Charger.Voltage >= 220000",
        "then": [
          {
            "op": "call",
            "target": "Switch.Off",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if (all(#Charger).charger_voltage >=| 220000) {\nany(#Switch).switch_off()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if (all(#Charger).charger_voltage >=| 220000) {\nany(#Switch).switch_off()\n}\"\n}"
}