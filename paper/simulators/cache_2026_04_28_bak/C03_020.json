{
  "command_eng": "If the temperature in sector 1 is 36.5 degrees or higher, set the target temperature to 30.",
  "connected_devices": {
    "Sector1_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Sector1",
        "TemperatureSensor"
      ]
    },
    "Sector2_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Sector2",
        "TemperatureSensor"
      ]
    },
    "Sector1_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Sector1",
        "AirConditioner"
      ]
    },
    "Sector2_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Sector2",
        "AirConditioner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "TemperatureSensor.Temperature >= 36.5",
        "then": [
          {
            "op": "call",
            "target": "AirConditioner.SetTargetTemperature",
            "args": {
              "Temperature": "30"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Sector1 #TemperatureSensor).temperatureSensor_temperature >= 36.5) {\n(#Sector1 #AirConditioner).airConditioner_setTargetTemperature(30)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Sector1 #TemperatureSensor).temperatureSensor_temperature >= 36.5) {\n(#Sector1 #AirConditioner).airConditioner_setTargetTemperature(30)\n}\"\n}"
}