{
  "command_eng": "If the carbon dioxide concentration in the farm is 800ppm or higher, sound the emergency siren.",
  "connected_devices": {
    "Farm_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Farm",
        "AirQualitySensor"
      ]
    },
    "Greenhouse_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Greenhouse",
        "AirQualitySensor"
      ]
    },
    "Farm_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Farm",
        "Siren"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "AirQualitySensor.CarbonDioxide >= 800",
        "then": [
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "emergency"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Farm #AirQualitySensor).airQualitySensor_carbonDioxide >= 800) {\n(#Farm #Siren).siren_setSirenMode(\"emergency\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Farm #AirQualitySensor).airQualitySensor_carbonDioxide >= 800) {\n(#Farm #Siren).siren_setSirenMode(\\\"emergency\\\")\\n}\"\n}"
}