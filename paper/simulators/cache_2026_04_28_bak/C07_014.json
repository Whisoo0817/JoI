{
  "command_eng": "When motion is detected in the bedroom, turn on the bedroom air conditioner.",
  "connected_devices": {
    "Bedroom_Motion": {
      "category": [
        "MotionSensor"
      ],
      "tags": [
        "Bedroom",
        "MotionSensor"
      ]
    },
    "LivingRoom_Motion": {
      "category": [
        "MotionSensor"
      ],
      "tags": [
        "LivingRoom",
        "MotionSensor"
      ]
    },
    "Bedroom_AC": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "AirConditioner"
      ]
    },
    "LivingRoom_AC": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "AirConditioner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "MotionSensor.Motion == true",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Switch.On",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#Bedroom #MotionSensor).motionSensor_motion == true)\n(#Bedroom #AirConditioner).switch_on()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#Bedroom #MotionSensor).motionSensor_motion == true)\n(#Bedroom #AirConditioner).switch_on()\"\n}"
}