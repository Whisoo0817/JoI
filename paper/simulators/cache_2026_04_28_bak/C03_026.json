{
  "command_eng": "If the living room illuminance is below 50 lux, turn on the living room light.",
  "connected_devices": {
    "LR_LightSensor": {
      "category": [
        "LightSensor"
      ],
      "tags": [
        "LivingRoom",
        "LightSensor"
      ]
    },
    "Bedroom_LightSensor": {
      "category": [
        "LightSensor"
      ],
      "tags": [
        "Bedroom",
        "LightSensor"
      ]
    },
    "Office_LightSensor": {
      "category": [
        "LightSensor"
      ],
      "tags": [
        "Office",
        "LightSensor"
      ]
    },
    "LR_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "Light",
        "Switch"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "Light",
        "Switch"
      ]
    },
    "Office_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Office",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "LightSensor.Brightness < 50",
        "then": [
          {
            "op": "call",
            "target": "Switch.On",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#LivingRoom #LightSensor).lightSensor_brightness < 50) {\n(#LivingRoom #Light).switch_on()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#LivingRoom #LightSensor).lightSensor_brightness < 50) {\n(#LivingRoom #Light).switch_on()\n}\"\n}"
}