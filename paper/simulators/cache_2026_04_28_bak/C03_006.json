{
  "command_eng": "If the charger current is 10 amperes or above, sound the emergency siren.",
  "connected_devices": {
    "Garage_Charger": {
      "category": [
        "Charger",
        "Switch"
      ],
      "tags": [
        "Charger",
        "Garage"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "Siren",
        "Main"
      ]
    },
    "Garage_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "Siren",
        "Garage"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "Charger.Current >= 10",
        "then": [
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "emergency"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Charger).charger_current >= 10) {\n(#Siren).siren_setSirenMode(\"emergency\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Charger).charger_current >= 10) {\n(#Siren).siren_setSirenMode(\\\"emergency\\\")\\n}\"\n}"
}