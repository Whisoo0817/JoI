{
  "command_eng": "When the safe is unlocked, sound the police siren.",
  "connected_devices": {
    "Study_Safe": {
      "category": [
        "Safe"
      ],
      "tags": [
        "Study",
        "Safe"
      ]
    },
    "Bedroom_Safe": {
      "category": [
        "Safe"
      ],
      "tags": [
        "Bedroom",
        "Safe"
      ]
    },
    "LivingRoom_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "Siren"
      ]
    },
    "Entrance_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "Entrance",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "Safe.SafeState == \"open\"",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Siren.SetSirenMode",
        "args": {
          "Mode": "police"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#Safe).safe_safeState == \"open\")\n(#Siren).siren_setSirenMode(\"police\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#Safe).safe_safeState == \\\"open\\\")\\n(#Siren).siren_setSirenMode(\\\"police\\\")\"\n}"
}