{
  "command_eng": "If the server room temperature is 30 degrees or higher and the AC is off, turn it on and sound the main emergency siren.",
  "connected_devices": {
    "Server_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "ServerRoom",
        "TemperatureSensor"
      ]
    },
    "Basement_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Basement",
        "TemperatureSensor"
      ]
    },
    "Server_AC": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "ServerRoom",
        "AirConditioner",
        "Switch"
      ]
    },
    "Basement_AC": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "Basement",
        "AirConditioner",
        "Switch"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    },
    "Garage_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Garage",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "TemperatureSensor.Temperature >= 30 && Switch.Switch == false",
        "then": [
          {
            "op": "call",
            "target": "Switch.On",
            "args": {}
          },
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "emergency"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#ServerRoom #TemperatureSensor).temperatureSensor_temperature >= 30 and (#ServerRoom #AirConditioner).switch_switch == false) {\n(#ServerRoom #AirConditioner).switch_on()\n(#Main #Siren).siren_setSirenMode(\"emergency\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#ServerRoom #TemperatureSensor).temperatureSensor_temperature >= 30 and (#ServerRoom #AirConditioner).switch_switch == false) {\n(#ServerRoom #AirConditioner).switch_on()\n(#Main #Siren).siren_setSirenMode(\\\"emergency\\\")\\n}\"\n}"
}