{
  "command_eng": "If all temperature sensors in sector 1 read 35 degrees or higher, set all air conditioners in sector 1 to cool mode.",
  "connected_devices": {
    "S1_Temp_1": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Sector1",
        "TemperatureSensor"
      ]
    },
    "S1_Temp_2": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Sector1",
        "TemperatureSensor"
      ]
    },
    "S2_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Sector2",
        "TemperatureSensor"
      ]
    },
    "S1_AC_1": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Sector1",
        "AirConditioner"
      ]
    },
    "S1_AC_2": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Sector1",
        "AirConditioner"
      ]
    },
    "S2_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Sector2",
        "AirConditioner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "TemperatureSensor.Temperature >= 35",
        "then": [
          {
            "op": "call",
            "target": "AirConditioner.SetAirConditionerMode",
            "args": {
              "Mode": "cool"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if (all(#Sector1 #TemperatureSensor).temperatureSensor_temperature >= 35) {\nall(#Sector1 #AirConditioner).airConditioner_setAirConditionerMode(\"cool\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if (all(#Sector1 #TemperatureSensor).temperatureSensor_temperature >= 35) {\nall(#Sector1 #AirConditioner).airConditioner_setAirConditionerMode(\\\"cool\\\")\\n}\"\n}"
}