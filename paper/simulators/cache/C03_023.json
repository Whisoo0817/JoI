{
  "command_eng": "If the temperature in the bedroom is 36.5 degrees or higher, set the bedroom air conditioner to 30 degrees.",
  "connected_devices": {
    "Bedroom_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Bedroom",
        "TemperatureSensor"
      ]
    },
    "LivingRoom_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "LivingRoom",
        "TemperatureSensor"
      ]
    },
    "Bedroom_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Bedroom",
        "AirConditioner"
      ]
    },
    "LivingRoom_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "LivingRoom",
        "AirConditioner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "TemperatureSensor.Temperature >= 36.5",
        "then": [
          {
            "op": "call",
            "target": "AirConditioner.SetTargetTemperature",
            "args": {
              "Temperature": "30"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Bedroom #TemperatureSensor).temperatureSensor_temperature >= 36.5) {\n(#Bedroom #AirConditioner).airConditioner_setTargetTemperature(30)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Bedroom #TemperatureSensor).temperatureSensor_temperature >= 36.5) {\n(#Bedroom #AirConditioner).airConditioner_setTargetTemperature(30)\n}\"\n}"
}