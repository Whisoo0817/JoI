{
  "command_eng": "Tell me the current humidity through the speaker.",
  "connected_devices": {
    "LivingRoom_Humidity": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "LivingRoom",
        "HumiditySensor"
      ]
    },
    "Bedroom_Humidity": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Bedroom",
        "HumiditySensor"
      ]
    },
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Kitchen_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Kitchen",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "read",
        "var": "Humidity",
        "src": "HumiditySensor.Humidity"
      },
      {
        "op": "call",
        "target": "Speaker.Speak",
        "args": {
          "Text": "The current humidity is $Humidity"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "Humidity = (#HumiditySensor).humiditySensor_humidity\n(#Speaker).speaker_speak(\"The current humidity is \" + Humidity)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"Humidity = (#HumiditySensor).humiditySensor_humidity\n(#Speaker).speaker_speak(\\\"The current humidity is \\\" + Humidity)\"\n}"
}