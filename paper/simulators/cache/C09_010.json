{
  "command_eng": "Start the dehumidifier in drying mode and change to refreshing mode after 1 hour.",
  "connected_devices": {
    "LivingRoom_Dehumidifier": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "LivingRoom",
        "Dehumidifier"
      ]
    },
    "Bedroom_Dehumidifier": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "Bedroom",
        "Dehumidifier"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "call",
        "target": "Dehumidifier.SetDehumidifierMode",
        "args": {
          "Mode": "drying"
        }
      },
      {
        "op": "delay",
        "duration": "1 HOUR"
      },
      {
        "op": "call",
        "target": "Dehumidifier.SetDehumidifierMode",
        "args": {
          "Mode": "refreshing"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "(#Dehumidifier).dehumidifier_setDehumidifierMode(\"drying\")\ndelay(1 HOUR)\n(#Dehumidifier).dehumidifier_setDehumidifierMode(\"refreshing\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"(#Dehumidifier).dehumidifier_setDehumidifierMode(\\\"drying\\\")\\ndelay(1 HOUR)\\n(#Dehumidifier).dehumidifier_setDehumidifierMode(\\\"refreshing\\\")\"\n}"
}