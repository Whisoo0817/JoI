{
  "command_eng": "If the living room light is on and the illuminance is 50 lux or higher, close the living room blind and set the AC to auto mode.",
  "connected_devices": {
    "LivingRoom_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "Light",
        "Switch"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "Light",
        "Switch"
      ]
    },
    "LivingRoom_LightSensor": {
      "category": [
        "LightSensor"
      ],
      "tags": [
        "LivingRoom",
        "LightSensor"
      ]
    },
    "Bedroom_LightSensor": {
      "category": [
        "LightSensor"
      ],
      "tags": [
        "Bedroom",
        "LightSensor"
      ]
    },
    "LivingRoom_Blind": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "LivingRoom",
        "Blind",
        "WindowCovering"
      ]
    },
    "Bedroom_Blind": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Bedroom",
        "Blind",
        "WindowCovering"
      ]
    },
    "LivingRoom_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "LivingRoom",
        "AirConditioner"
      ]
    },
    "Bedroom_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Bedroom",
        "AirConditioner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "Light.Switch == true and LightSensor.Brightness >= 50",
        "then": [
          {
            "op": "call",
            "target": "WindowCovering.DownOrClose",
            "args": {}
          },
          {
            "op": "call",
            "target": "AirConditioner.SetAirConditionerMode",
            "args": {
              "Mode": "auto"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Light #LivingRoom).switch_switch == true and (#LightSensor #LivingRoom).lightSensor_brightness >= 50) {\n(#WindowCovering #LivingRoom #Blind).windowCovering_downOrClose()\n(#AirConditioner #LivingRoom).airConditioner_setAirConditionerMode(\"auto\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Light #LivingRoom).switch_switch == true and (#LightSensor #LivingRoom).lightSensor_brightness >= 50) {\n(#WindowCovering #LivingRoom #Blind).windowCovering_downOrClose()\n(#AirConditioner #LivingRoom).airConditioner_setAirConditionerMode(\\\"auto\\\")\\n}\"\n}"
}