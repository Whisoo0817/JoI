{
  "command_eng": "When the indoor very fine dust level becomes 35 or higher, set the air purifier to high.",
  "connected_devices": {
    "LivingRoom_AirQualitySensor": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "LivingRoom",
        "AirQualitySensor"
      ]
    },
    "Bedroom_AirQualitySensor": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Bedroom",
        "AirQualitySensor"
      ]
    },
    "LivingRoom_AirPurifier": {
      "category": [
        "AirPurifier",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "AirPurifier"
      ]
    },
    "Bedroom_AirPurifier": {
      "category": [
        "AirPurifier",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "AirPurifier"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "AirQualitySensor.VeryFineDustLevel >= 35",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "AirPurifier.SetAirPurifierMode",
        "args": {
          "Mode": "high"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#AirQualitySensor).airQualitySensor_veryFineDustLevel >= 35)\n(#AirPurifier).airPurifier_setAirPurifierMode(\"high\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#AirQualitySensor).airQualitySensor_veryFineDustLevel >= 35)\n(#AirPurifier).airPurifier_setAirPurifierMode(\\\"high\\\")\"\n}"
}