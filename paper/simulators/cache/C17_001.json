{
  "command_eng": "Every 10 minutes, if the temperature is 30 degrees or higher, set the air conditioner to cool mode.",
  "connected_devices": {
    "LivingRoom_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "LivingRoom",
        "TemperatureSensor"
      ]
    },
    "LivingRoom_AC": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "AirConditioner",
        "Switch"
      ]
    },
    "Bedroom_AC": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "AirConditioner",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "10 MIN",
        "body": [
          {
            "op": "if",
            "cond": "TemperatureSensor.Temperature >= 30",
            "then": [
              {
                "op": "call",
                "target": "AirConditioner.SetAirConditionerMode",
                "args": {
                  "Mode": "cool"
                }
              }
            ],
            "else": []
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 600000,
    "script": "if ((#TemperatureSensor #LivingRoom).temperatureSensor_temperature >= 30) {\n(#AirConditioner).airConditioner_setAirConditionerMode(\"cool\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 600000,\n  \"script\": \"if ((#TemperatureSensor #LivingRoom).temperatureSensor_temperature >= 30) {\n(#AirConditioner).airConditioner_setAirConditionerMode(\\\"cool\\\")\\n}\"\n}"
}