{
  "command_eng": "If the illuminance is 100 lux or lower and a person is being detected, set the speaker volume to 30 and play relax.mp3 music.",
  "connected_devices": {
    "Living_LightSensor": {
      "category": [
        "LightSensor"
      ],
      "tags": [
        "Living",
        "LightSensor"
      ]
    },
    "Bedroom_LightSensor": {
      "category": [
        "LightSensor"
      ],
      "tags": [
        "Bedroom",
        "LightSensor"
      ]
    },
    "Living_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Living",
        "PresenceSensor"
      ]
    },
    "Bedroom_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Bedroom",
        "PresenceSensor"
      ]
    },
    "Living_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Living",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "LightSensor.Brightness <= 100 and PresenceSensor.Presence == true",
        "then": [
          {
            "op": "call",
            "target": "Speaker.SetVolume",
            "args": {
              "Volume": 30
            }
          },
          {
            "op": "call",
            "target": "Speaker.Play",
            "args": {
              "MediaSource": "relax.mp3"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#LightSensor).lightSensor_brightness <= 100 and (#PresenceSensor).presenceSensor_presence == true) {\n(#Speaker).speaker_setVolume(30)\n(#Speaker).speaker_play(\"relax.mp3\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#LightSensor).lightSensor_brightness <= 100 and (#PresenceSensor).presenceSensor_presence == true) {\n(#Speaker).speaker_setVolume(30)\n(#Speaker).speaker_play(\\\"relax.mp3\\\")\\n}\"\n}"
}