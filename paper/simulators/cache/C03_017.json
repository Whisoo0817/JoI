{
  "command_eng": "If any presence sensor in the house is currently in the detected state, set the siren to emergency mode.",
  "connected_devices": {
    "House_Presence_1": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "House",
        "PresenceSensor"
      ]
    },
    "House_Presence_2": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "House",
        "PresenceSensor"
      ]
    },
    "Outdoor_PresenceSensor": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Outdoor",
        "PresenceSensor"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    },
    "Garage_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Garage",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "PresenceSensor.Presence == true",
        "then": [
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "emergency"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if (any(#House #PresenceSensor).presenceSensor_presence == true) {\n(#Siren).siren_setSirenMode(\"emergency\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if (any(#House #PresenceSensor).presenceSensor_presence == true) {\n(#Siren).siren_setSirenMode(\\\"emergency\\\")\\n}\"\n}"
}