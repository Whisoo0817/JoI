{
  "command_eng": "Announce the fine dust level through the speaker.",
  "connected_devices": {
    "LivingRoom_AirQuality": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "LivingRoom",
        "AirQualitySensor"
      ]
    },
    "Bedroom_AirQuality": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Bedroom",
        "AirQualitySensor"
      ]
    },
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Kitchen_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Kitchen",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "read",
        "var": "FineDustLevel",
        "src": "AirQualitySensor.FineDustLevel"
      },
      {
        "op": "call",
        "target": "Speaker.Speak",
        "args": {
          "Text": "Fine dust level is $FineDustLevel"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "FineDustLevel = (#AirQualitySensor).airQualitySensor_fineDustLevel\n(#Speaker).speaker_speak(\"Fine dust level is \" + FineDustLevel)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"FineDustLevel = (#AirQualitySensor).airQualitySensor_fineDustLevel\n(#Speaker).speaker_speak(\\\"Fine dust level is \\\" + FineDustLevel)\"\n}"
}