{
  "command_eng": "Repeat opening and closing the bedroom window every 2 hours.",
  "connected_devices": {
    "BR_Win": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Bedroom",
        "Window",
        "WindowCovering"
      ]
    },
    "LR_Win": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "LivingRoom",
        "Window",
        "WindowCovering"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "2 HOUR",
        "body": [
          {
            "op": "call",
            "target": "WindowCovering.UpOrOpen",
            "args": {}
          },
          {
            "op": "delay",
            "duration": "2 HOUR"
          },
          {
            "op": "call",
            "target": "WindowCovering.DownOrClose",
            "args": {}
          },
          {
            "op": "delay",
            "duration": "2 HOUR"
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 7200000,
    "script": "state := \"open\"\nif (state == \"open\") {\n(#WindowCovering #Bedroom #Window).windowCovering_upOrOpen()\n    state = \"closed\"\n}\nelse {\n(#WindowCovering #Bedroom #Window).windowCovering_downOrClose()\n    state = \"open\"\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 7200000,\n  \"script\": \"state := \\\"open\\\"\\nif (state == \\\"open\\\") {\\n(#WindowCovering #Bedroom #Window).windowCovering_upOrOpen()\\n    state = \\\"closed\\\"\\n}\\nelse {\\n(#WindowCovering #Bedroom #Window).windowCovering_downOrClose()\\n    state = \\\"open\\\"\\n}\"\n}"
}