{
  "command_eng": "Every 30 seconds from 10 PM to 11 PM, check for rain; if it rains, close the window.",
  "connected_devices": {
    "Outside_RainSensor": {
      "category": [
        "RainSensor"
      ],
      "tags": [
        "Outside",
        "RainSensor"
      ]
    },
    "Main_Window": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Main",
        "Window",
        "WindowCovering"
      ]
    },
    "Rooftop_RainSensor": {
      "category": [
        "RainSensor"
      ],
      "tags": [
        "Rooftop",
        "RainSensor"
      ]
    },
    "Bedroom_Window": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Bedroom",
        "Window",
        "WindowCovering"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 22 * * *"
      },
      {
        "op": "cycle",
        "until": "clock.time >= 2300",
        "period": "30 SEC",
        "body": [
          {
            "op": "if",
            "cond": "RainSensor.Rain == true",
            "then": [
              {
                "op": "call",
                "target": "WindowCovering.DownOrClose",
                "args": {}
              }
            ],
            "else": []
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 22 * * *",
    "period": 30000,
    "script": "if (clock.time >= 2300) {\nbreak\n}\nif (all(#RainSensor).rainSensor_rain ==| true) {\n(#WindowCovering #Window).windowCovering_downOrClose()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 22 * * *\",\n  \"period\": 30000,\n  \"script\": \"if (clock.time >= 2300) {\nbreak\n}\nif (all(#RainSensor).rainSensor_rain ==| true) {\n(#WindowCovering #Window).windowCovering_downOrClose()\n}\"\n}"
}