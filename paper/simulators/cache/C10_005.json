{
  "command_eng": "When any presence sensor in the house detects presence, sound all emergency sirens after 10 seconds.",
  "connected_devices": {
    "House_Presence_1": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "House",
        "PresenceSensor"
      ]
    },
    "House_Presence_2": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "House",
        "PresenceSensor"
      ]
    },
    "Garage_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Garage",
        "PresenceSensor"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "House",
        "Siren",
        "Switch"
      ]
    },
    "Sub_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "House",
        "Siren",
        "Switch"
      ]
    },
    "Garden_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "Garden",
        "Siren",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "PresenceSensor.Presence == true",
        "edge": "none"
      },
      {
        "op": "delay",
        "duration": "10 SEC"
      },
      {
        "op": "call",
        "target": "Siren.SetSirenMode",
        "args": {
          "Mode": "emergency"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until(all(#PresenceSensor #House).presenceSensor_presence ==| true)\ndelay(10 SEC)\nall(#Siren).siren_setSirenMode(\"emergency\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until(all(#PresenceSensor #House).presenceSensor_presence ==| true)\ndelay(10 SEC)\nall(#Siren).siren_setSirenMode(\\\"emergency\\\")\"\n}"
}