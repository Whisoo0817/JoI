{
  "command_eng": "If no motion is detected but the door is open, take a photo and output \"Warning\" through the speaker.",
  "connected_devices": {
    "Entrance_Motion": {
      "category": [
        "MotionSensor"
      ],
      "tags": [
        "Entrance",
        "MotionSensor"
      ]
    },
    "Garage_Motion": {
      "category": [
        "MotionSensor"
      ],
      "tags": [
        "Garage",
        "MotionSensor"
      ]
    },
    "Living_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Living",
        "Door"
      ]
    },
    "Bedroom_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Bedroom",
        "Door"
      ]
    },
    "Entrance_Camera": {
      "category": [
        "Camera"
      ],
      "tags": [
        "Entrance",
        "Camera"
      ]
    },
    "Garage_Camera": {
      "category": [
        "Camera"
      ],
      "tags": [
        "Garage",
        "Camera"
      ]
    },
    "Living_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Living",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "MotionSensor.Motion == false && Door.DoorState == \"open\"",
        "then": [
          {
            "op": "call",
            "target": "Camera.CaptureImage",
            "args": {}
          },
          {
            "op": "call",
            "target": "Speaker.Speak",
            "args": {
              "Text": "Warning"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if (not any(#MotionSensor).motionSensor_motion and (#Door).door_doorState == \"open\") {\n(#Camera).camera_captureImage()\n(#Speaker).speaker_speak(\"Warning\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if (not any(#MotionSensor).motionSensor_motion and (#Door).door_doorState == \\\"open\\\") {\\n(#Camera).camera_captureImage()\\n(#Speaker).speaker_speak(\\\"Warning\\\")\\n}\"\n}"
}