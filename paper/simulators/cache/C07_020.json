{
  "command_eng": "When the laundry room dryer's spin speed drops to 5 or below, announce through the living room speaker that the laundry is done.",
  "connected_devices": {
    "LaundryRoom_LaundryDryer": {
      "category": [
        "LaundryDryer"
      ],
      "tags": [
        "LaundryRoom",
        "LaundryDryer"
      ]
    },
    "Basement_LaundryDryer": {
      "category": [
        "LaundryDryer"
      ],
      "tags": [
        "Basement",
        "LaundryDryer"
      ]
    },
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Kitchen_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Kitchen",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "LaundryDryer.SpinSpeed <= 5",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Speaker.Speak",
        "args": {
          "Text": "the laundry is done"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#LaundryDryer #LaundryRoom).laundryDryer_spinSpeed <= 5)\n(#Speaker #LivingRoom).speaker_speak(\"the laundry is done\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#LaundryDryer #LaundryRoom).laundryDryer_spinSpeed <= 5)\n(#Speaker #LivingRoom).speaker_speak(\\\"the laundry is done\\\")\"\n}"
}