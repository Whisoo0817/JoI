{
  "command_eng": "When the oven enters heating mode, switch it to microwave mode after 3 seconds.",
  "connected_devices": {
    "Kitchen_Oven": {
      "category": [
        "Oven"
      ],
      "tags": [
        "Kitchen",
        "Oven"
      ]
    },
    "Basement_Oven": {
      "category": [
        "Oven"
      ],
      "tags": [
        "Basement",
        "Oven"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "Oven.OvenMode == \"heating\"",
        "edge": "rising"
      },
      {
        "op": "delay",
        "duration": "3 SEC"
      },
      {
        "op": "call",
        "target": "Oven.SetOvenMode",
        "args": {
          "Mode": "Microwave"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#Oven).oven_ovenMode == \"heating\")\ndelay(3 SEC)\n(#Oven).oven_setOvenMode(\"Microwave\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#Oven).oven_ovenMode == \\\"heating\\\")\\ndelay(3 SEC)\\n(#Oven).oven_setOvenMode(\\\"Microwave\\\")\"\n}"
}