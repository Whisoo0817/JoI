{
  "command_eng": "Check the fine dust level every hour; if it's 200 or higher, set the air purifier to high speed; if it's 100 or lower, set it to low speed.",
  "connected_devices": {
    "Living_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Living",
        "AirQualitySensor"
      ]
    },
    "Bedroom_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Bedroom",
        "AirQualitySensor"
      ]
    },
    "Living_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Living",
        "AirPurifier"
      ]
    },
    "Bedroom_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Bedroom",
        "AirPurifier"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "1 HOUR",
        "body": [
          {
            "op": "if",
            "cond": "AirQualitySensor.FineDustLevel >= 200",
            "then": [
              {
                "op": "call",
                "target": "AirPurifier.SetAirPurifierMode",
                "args": {
                  "Mode": "high"
                }
              }
            ],
            "else": [
              {
                "op": "if",
                "cond": "AirQualitySensor.FineDustLevel <= 100",
                "then": [
                  {
                    "op": "call",
                    "target": "AirPurifier.SetAirPurifierMode",
                    "args": {
                      "Mode": "high"
                    }
                  }
                ],
                "else": []
              }
            ]
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 3600000,
    "script": "if ((#AirQualitySensor).airQualitySensor_fineDustLevel >= 200) {\n(#AirPurifier).airPurifier_setAirPurifierMode(\"high\")\n}\nelse {\nif ((#AirQualitySensor).airQualitySensor_fineDustLevel <= 100) {\n(#AirPurifier).airPurifier_setAirPurifierMode(\"low\")\n}\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 3600000,\n  \"script\": \"if ((#AirQualitySensor).airQualitySensor_fineDustLevel >= 200) {\n(#AirPurifier).airPurifier_setAirPurifierMode(\\\"high\\\")\\n}\\nelse {\\nif ((#AirQualitySensor).airQualitySensor_fineDustLevel <= 100) {\\n(#AirPurifier).airPurifier_setAirPurifierMode(\\\"low\\\")\\n}\\n}\"\n}"
}