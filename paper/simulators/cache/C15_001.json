{
  "command_eng": "At 6 PM, set the level of all blinds with odd tags on the wall to 50%.",
  "connected_devices": {
    "Wall_Blind_1": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Wall",
        "Odd",
        "Blind",
        "WindowCovering",
        "LivingRoom"
      ]
    },
    "Wall_Blind_3": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Wall",
        "Odd",
        "Blind",
        "WindowCovering",
        "Kitchen"
      ]
    },
    "Floor_Blind_2": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Floor",
        "Even",
        "Blind",
        "WindowCovering",
        "Bedroom"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 18 * * *"
      },
      {
        "op": "call",
        "target": "WindowCovering.SetLevel",
        "args": {
          "Level": 50
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 18 * * *",
    "period": 0,
    "script": "all(#WindowCovering #Wall #Odd #Blind).windowCovering_setLevel(50)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 18 * * *\",\n  \"period\": 0,\n  \"script\": \"all(#WindowCovering #Wall #Odd #Blind).windowCovering_setLevel(50)\"\n}"
}