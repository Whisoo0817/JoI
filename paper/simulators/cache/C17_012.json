      ]
    },
    "LR_Light": {
      "category": [
        "Light",
        "Switch",
        "LevelControl"
      ],
      "tags": [
        "LivingRoom",
        "Light",
        "Switch",
        "LevelControl"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light",
        "Switch",
        "LevelControl"
      ],
      "tags": [
        "Bedroom",
        "Light",
        "Switch",
        "LevelControl"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "30 MIN",
        "body": [
          {
            "op": "if",
            "cond": "Light.CurrentBrightness >= 50",
            "then": [
              {
                "op": "call",
                "target": "Light.MoveToBrightness",
                "args": {
                  "Brightness": 0.0,
                  "Rate": 0.0
                }
              }
            ],
            "else": []
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 1800000,
    "script": "if (all(#Light #Hallway).light_currentBrightness >=| 50) {\nall(#Light #Hallway).light_moveToBrightness(0.0, 0.0)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 1800000,\n  \"script\": \"if (all(#Light #Hallway).light_currentBrightness >=| 50) {\nall(#Light #Hallway).light_moveToBrightness(0.0, 0.0)\n}\"\n}"
}