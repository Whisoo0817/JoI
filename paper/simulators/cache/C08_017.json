{
  "command_eng": "When button 4 of the multi-button is pressed, set all lights to night mode at 10% brightness.",
  "connected_devices": {
    "Main_MB": {
      "category": [
        "MultiButton"
      ],
      "tags": [
        "LivingRoom",
        "MultiButton"
      ]
    },
    "Hall_MB": {
      "category": [
        "MultiButton"
      ],
      "tags": [
        "Hallway",
        "MultiButton"
      ]
    },
    "LR_Light": {
      "category": [
        "Light"
      ],
      "tags": [
        "LivingRoom",
        "Light"
      ]
    },
    "Hall_Light": {
      "category": [
        "Light"
      ],
      "tags": [
        "Hallway",
        "Light"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light"
      ],
      "tags": [
        "Bedroom",
        "Light"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "MultiButton.Button4 == \"pushed\"",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Light.MoveToColorTemperature",
        "args": {
          "ColorTemperatureMireds": 650,
          "TransitionTime": 0.0
        }
      },
      {
        "op": "call",
        "target": "Light.MoveToBrightness",
        "args": {
          "Brightness": 10.0,
          "Rate": 0.0
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#MultiButton).multiButton_button4 == \"pushed\")\nall(#Light).light_moveToColorTemperature(650, 0)\nall(#Light).light_moveToBrightness(10, 0)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#MultiButton).multiButton_button4 == \\\"pushed\\\")\\nall(#Light).light_moveToColorTemperature(650, 0)\\nall(#Light).light_moveToBrightness(10, 0)\"\n}"
}