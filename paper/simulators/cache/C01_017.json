{
  "command_eng": "Tell me today's menu using the speaker.",
  "connected_devices": {
    "System_MenuProvider": {
      "category": [
        "MenuProvider"
      ],
      "tags": [
        "MenuProvider"
      ]
    },
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Kitchen_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Kitchen",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "call",
        "target": "Speaker.Speak",
        "args": {
          "Text": "Today's menu is $TodayMenu"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "TodayMenu = (#MenuProvider).menuProvider_todayMenu\n(#Speaker).speaker_speak(\"Today's menu is \" + TodayMenu)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"TodayMenu = (#MenuProvider).menuProvider_todayMenu\n(#Speaker).speaker_speak(\\\"Today's menu is \\\" + TodayMenu)\"\n}"
}