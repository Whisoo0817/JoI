{
  "command_eng": "If the parking lot carbon dioxide level exceeds 900ppm, set the parking lot air purifier to high mode.",
  "connected_devices": {
    "P_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "ParkingLot",
        "AirQualitySensor"
      ]
    },
    "Warehouse_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Warehouse",
        "AirQualitySensor"
      ]
    },
    "Office_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Office",
        "AirQualitySensor"
      ]
    },
    "P_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "ParkingLot",
        "AirPurifier"
      ]
    },
    "Warehouse_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Warehouse",
        "AirPurifier"
      ]
    },
    "Office_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Office",
        "AirPurifier"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "AirQualitySensor.CarbonDioxide > 900",
        "then": [
          {
            "op": "call",
            "target": "AirPurifier.SetAirPurifierMode",
            "args": {
              "Mode": "high"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#AirQualitySensor #ParkingLot).airQualitySensor_carbonDioxide > 900) {\n(#AirPurifier #ParkingLot).airPurifier_setAirPurifierMode(\"high\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#AirQualitySensor #ParkingLot).airQualitySensor_carbonDioxide > 900) {\n(#AirPurifier #ParkingLot).airPurifier_setAirPurifierMode(\\\"high\\\")\\n}\"\n}"
}