{
  "command_eng": "Start the robot vacuum cleaner in auto mode and switch to manual mode after 30 minutes.",
  "connected_devices": {
    "LivingRoom_RobotVacuumCleaner": {
      "category": [
        "RobotVacuumCleaner"
      ],
      "tags": [
        "LivingRoom",
        "RobotVacuumCleaner"
      ]
    },
    "Kitchen_RobotVacuumCleaner": {
      "category": [
        "RobotVacuumCleaner"
      ],
      "tags": [
        "Kitchen",
        "RobotVacuumCleaner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "call",
        "target": "RobotVacuumCleaner.SetRobotVacuumCleanerCleaningMode",
        "args": {
          "Mode": "auto"
        }
      },
      {
        "op": "delay",
        "duration": "30 MIN"
      },
      {
        "op": "call",
        "target": "RobotVacuumCleaner.SetRobotVacuumCleanerCleaningMode",
        "args": {
          "Mode": "auto"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "(#RobotVacuumCleaner).robotVacuumCleaner_setRobotVacuumCleanerCleaningMode(\"auto\")\ndelay(30 MIN)\n(#RobotVacuumCleaner).robotVacuumCleaner_setRobotVacuumCleanerCleaningMode(\"auto\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"(#RobotVacuumCleaner).robotVacuumCleaner_setRobotVacuumCleanerCleaningMode(\\\"auto\\\")\\ndelay(30 MIN)\\n(#RobotVacuumCleaner).robotVacuumCleaner_setRobotVacuumCleanerCleaningMode(\\\"auto\\\")\"\n}"
}