{
  "command_eng": "Every hour, repeat opening and closing the door.",
  "connected_devices": {
    "Entrance_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Entrance",
        "Door"
      ]
    },
    "Garage_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Garage",
        "Door"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 * * * *"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "1 HOUR",
        "body": [
          {
            "op": "call",
            "target": "Door.Open",
            "args": {}
          },
          {
            "op": "call",
            "target": "Door.Close",
            "args": {}
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 * * * *",
    "period": 3600000,
    "script": "(#Door).door_open()\n(#Door).door_close()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 * * * *\",\n  \"period\": 3600000,\n  \"script\": \"(#Door).door_open()\n(#Door).door_close()\"\n}"
}