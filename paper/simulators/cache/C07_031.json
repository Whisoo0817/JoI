{
  "command_eng": "If the server room temperature exceeds 35 degrees, set the server room air conditioner to cool mode at 18 degrees.",
  "connected_devices": {
    "SR_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "ServerRoom",
        "TemperatureSensor"
      ]
    },
    "Basement_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Basement",
        "TemperatureSensor"
      ]
    },
    "Office_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Office",
        "TemperatureSensor"
      ]
    },
    "SR_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "ServerRoom",
        "AirConditioner"
      ]
    },
    "Basement_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Basement",
        "AirConditioner"
      ]
    },
    "Office_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Office",
        "AirConditioner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "TemperatureSensor.Temperature > 35",
        "then": [
          {
            "op": "call",
            "target": "AirConditioner.SetAirConditionerMode",
            "args": {
              "Mode": "cool"
            }
          },
          {
            "op": "call",
            "target": "AirConditioner.SetTargetTemperature",
            "args": {
              "Temperature": 18.0
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#TemperatureSensor #ServerRoom).temperatureSensor_temperature > 35) {\n(#AirConditioner #ServerRoom).airConditioner_setAirConditionerMode(\"cool\")\n(#AirConditioner #ServerRoom).airConditioner_setTargetTemperature(18.0)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#TemperatureSensor #ServerRoom).temperatureSensor_temperature > 35) {\n(#AirConditioner #ServerRoom).airConditioner_setAirConditionerMode(\\\"cool\\\")\\n(#AirConditioner #ServerRoom).airConditioner_setTargetTemperature(18.0)\\n}\"\n}"
}