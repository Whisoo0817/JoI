{
  "command_eng": "Set the air conditioner temperature to 24 degrees and change it to 26 degrees after 1 hour.",
  "connected_devices": {
    "LivingRoom_AirConditioner": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "AirConditioner"
      ]
    },
    "Bedroom_AirConditioner": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "AirConditioner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "call",
        "target": "AirConditioner.SetTargetTemperature",
        "args": {
          "Temperature": 24.0
        }
      },
      {
        "op": "delay",
        "duration": "1 HOUR"
      },
      {
        "op": "call",
        "target": "AirConditioner.SetTargetTemperature",
        "args": {
          "Temperature": 24.0
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "(#AirConditioner).airConditioner_setTargetTemperature(24.0)\ndelay(1 HOUR)\n(#AirConditioner).airConditioner_setTargetTemperature(24.0)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"(#AirConditioner).airConditioner_setTargetTemperature(24.0)\ndelay(1 HOUR)\n(#AirConditioner).airConditioner_setTargetTemperature(24.0)\"\n}"
}