{
  "command_eng": "If the sector 1 temperature is 30 degrees or higher, set the sector 1 air conditioner target temperature to 22 degrees.",
  "connected_devices": {
    "S1_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Sector1",
        "TemperatureSensor"
      ]
    },
    "S2_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Sector2",
        "TemperatureSensor"
      ]
    },
    "S3_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Sector3",
        "TemperatureSensor"
      ]
    },
    "S1_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Sector1",
        "AirConditioner"
      ]
    },
    "S2_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Sector2",
        "AirConditioner"
      ]
    },
    "S3_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Sector3",
        "AirConditioner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "TemperatureSensor.Temperature >= 30",
        "then": [
          {
            "op": "call",
            "target": "AirConditioner.SetTargetTemperature",
            "args": {
              "Temperature": 22.0
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#TemperatureSensor #Sector1).temperatureSensor_temperature >= 30) {\n(#AirConditioner #Sector1).airConditioner_setTargetTemperature(22.0)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#TemperatureSensor #Sector1).temperatureSensor_temperature >= 30) {\n(#AirConditioner #Sector1).airConditioner_setTargetTemperature(22.0)\n}\"\n}"
}