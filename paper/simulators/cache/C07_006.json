{
  "command_eng": "When smoke is detected, sound the fire alarm with the siren.",
  "connected_devices": {
    "LivingRoom_SmokeDetector": {
      "category": [
        "SmokeDetector"
      ],
      "tags": [
        "LivingRoom",
        "SmokeDetector"
      ]
    },
    "Kitchen_SmokeDetector": {
      "category": [
        "SmokeDetector"
      ],
      "tags": [
        "Kitchen",
        "SmokeDetector"
      ]
    },
    "LivingRoom_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "Siren"
      ]
    },
    "Entrance_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "Entrance",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "SmokeDetector.Smoke == true",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Siren.SetSirenMode",
        "args": {
          "Mode": "fire"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#SmokeDetector).smokeDetector_smoke == true)\n(#Siren).siren_setSirenMode(\"fire\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#SmokeDetector).smokeDetector_smoke == true)\n(#Siren).siren_setSirenMode(\\\"fire\\\")\"\n}"
}