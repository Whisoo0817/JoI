{
  "command_eng": "At midnight, close the door and check the light every hour until 6 AM; if the brightness is greater than 30, lower it to 10.",
  "connected_devices": {
    "Entrance_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Entrance",
        "Door"
      ]
    },
    "Garage_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Garage",
        "Door"
      ]
    },
    "Living_Light": {
      "category": [
        "Light",
        "LevelControl"
      ],
      "tags": [
        "Living",
        "Light",
        "LevelControl"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light",
        "LevelControl"
      ],
      "tags": [
        "Bedroom",
        "Light",
        "LevelControl"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 0 * * *"
      },
      {
        "op": "call",
        "target": "Door.Close",
        "args": {}
      },
      {
        "op": "cycle",
        "until": "clock.time >= 0600",
        "period": "1 HOUR",
        "body": [
          {
            "op": "if",
            "cond": "Light.CurrentBrightness > 30",
            "then": [
              {
                "op": "call",
                "target": "Light.MoveToBrightness",
                "args": {
                  "Brightness": 10.0,
                  "Rate": 0.0
                }
              }
            ],
            "else": []
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 0 * * *",
    "period": 3600000,
    "script": "if (clock.time >= 0600) {\nbreak\n}\nif ((#Light).light_currentBrightness > 30) {\n(#Light).light_moveToBrightness(10.0, 0.0)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 0 * * *\",\n  \"period\": 3600000,\n  \"script\": \"if (clock.time >= 0600) {\nbreak\n}\nif ((#Light).light_currentBrightness > 30) {\n(#Light).light_moveToBrightness(10.0, 0.0)\n}\"\n}"
}