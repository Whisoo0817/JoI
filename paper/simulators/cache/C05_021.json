{
  "command_eng": "If the face ID 'family' is recognized at the entrance and the door lock is locked , unlock the door lock and open the door.",
  "connected_devices": {
    "Entrance_Face": {
      "category": [
        "FaceRecognizer"
      ],
      "tags": [
        "Entrance",
        "FaceRecognizer"
      ]
    },
    "Garage_Face": {
      "category": [
        "FaceRecognizer"
      ],
      "tags": [
        "Garage",
        "FaceRecognizer"
      ]
    },
    "Entrance_Lock": {
      "category": [
        "DoorLock"
      ],
      "tags": [
        "Entrance",
        "DoorLock"
      ]
    },
    "Garage_Lock": {
      "category": [
        "DoorLock"
      ],
      "tags": [
        "Garage",
        "DoorLock"
      ]
    },
    "Entrance_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Entrance",
        "Door"
      ]
    },
    "Garage_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Garage",
        "Door"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "FaceRecognizer.RecognizedResult == 'family' && DoorLock.DoorLockState == 'closed'",
        "then": [
          {
            "op": "call",
            "target": "DoorLock.Unlock",
            "args": {}
          },
          {
            "op": "call",
            "target": "Door.Open",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Entrance #FaceRecognizer).faceRecognizer_recognizedResult == \"family\" and (#Entrance #DoorLock).doorLock_doorLockState == \"closed\") {\n(#Entrance #DoorLock).doorLock_unlock()\n(#Entrance #Door).door_open()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Entrance #FaceRecognizer).faceRecognizer_recognizedResult == \\\"family\\\" and (#Entrance #DoorLock).doorLock_doorLockState == \\\"closed\\\") {\\n(#Entrance #DoorLock).doorLock_unlock()\\n(#Entrance #Door).door_open()\\n}\"\n}"
}