{
  "command_eng": "Every minute, if the humidity of all sensors in Group2 is 50% or higher, set all dehumidifiers to refresh mode.",
  "connected_devices": {
    "Grp2_Hum_1": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Group2",
        "HumiditySensor",
        "North"
      ]
    },
    "Grp2_Hum_2": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Group2",
        "HumiditySensor",
        "South"
      ]
    },
    "Grp1_Hum_1": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Group1",
        "HumiditySensor",
        "East"
      ]
    },
    "Dehum_1": {
      "category": [
        "Dehumidifier",
        "Switch"
      ],
      "tags": [
        "Main",
        "Dehumidifier",
        "Switch"
      ]
    },
    "Dehum_2": {
      "category": [
        "Dehumidifier",
        "Switch"
      ],
      "tags": [
        "Backup",
        "Dehumidifier",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 * * * *"
      },
      {
        "op": "if",
        "cond": "all(#Grp2 #HumiditySensor).Humidity >= 50",
        "then": [
          {
            "op": "call",
            "target": "Dehumidifier.SetDehumidifierMode",
            "args": {
              "Mode": "refreshing"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 * * * *",
    "period": 60000,
    "script": "if (all(#HumiditySensor #Group2).humiditySensor_humidity >= 50) {\nall(#Dehumidifier).dehumidifier_setDehumidifierMode(\"refreshing\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 * * * *\",\n  \"period\": 60000,\n  \"script\": \"if (all(#HumiditySensor #Group2).humiditySensor_humidity >= 50) {\nall(#Dehumidifier).dehumidifier_setDehumidifierMode(\\\"refreshing\\\")\\n}\"\n}"
}