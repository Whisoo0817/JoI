{
  "command_eng": "If the noise level is 80 or higher and no person is being detected, stop speaker playbackand sound the emergency siren.",
  "connected_devices": {
    "Living_Sound": {
      "category": [
        "SoundSensor"
      ],
      "tags": [
        "Living",
        "SoundSensor"
      ]
    },
    "Entrance_Sound": {
      "category": [
        "SoundSensor"
      ],
      "tags": [
        "Entrance",
        "SoundSensor"
      ]
    },
    "Living_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Living",
        "PresenceSensor"
      ]
    },
    "Bedroom_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Bedroom",
        "PresenceSensor"
      ]
    },
    "Living_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Living",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    },
    "Entrance_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Entrance",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "SoundSensor.Sound >= 80 && PresenceSensor.Presence == false",
        "then": [
          {
            "op": "call",
            "target": "Speaker.Stop",
            "args": {}
          },
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "emergency"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#SoundSensor).soundSensor_sound >= 80 and not (#PresenceSensor).presenceSensor_presence) {\n(#Speaker).speaker_stop()\n(#Siren).siren_setSirenMode(\"emergency\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#SoundSensor).soundSensor_sound >= 80 and not (#PresenceSensor).presenceSensor_presence) {\n(#Speaker).speaker_stop()\n(#Siren).siren_setSirenMode(\\\"emergency\\\")\\n}\"\n}"
}