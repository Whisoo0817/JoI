{
  "command_eng": "When a smoke is detected in the kitchen, close the kitchen valve.",
  "connected_devices": {
    "Kitchen_Smoke": {
      "category": [
        "SmokeDetector"
      ],
      "tags": [
        "Kitchen",
        "SmokeDetector"
      ]
    },
    "Laundry_Smoke": {
      "category": [
        "SmokeDetector"
      ],
      "tags": [
        "Laundry",
        "SmokeDetector"
      ]
    },
    "Kitchen_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Kitchen",
        "Valve"
      ]
    },
    "Bathroom_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Bathroom",
        "Valve"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "SmokeDetector.Smoke == true",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Valve.Close",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#Kitchen #SmokeDetector).smokeDetector_smoke == true)\n(#Kitchen #Valve).valve_close()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#Kitchen #SmokeDetector).smokeDetector_smoke == true)\n(#Kitchen #Valve).valve_close()\"\n}"
}