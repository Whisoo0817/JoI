{
  "command_eng": "Repeat opening and closing the living room blind every hour.",
  "connected_devices": {
    "LR_Blind": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "LivingRoom",
        "Blind",
        "WindowCovering"
      ]
    },
    "Bedroom_Blind": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Bedroom",
        "Blind",
        "WindowCovering"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "1 HOUR",
        "body": [
          {
            "op": "call",
            "target": "WindowCovering.UpOrOpen",
            "args": {}
          },
          {
            "op": "call",
            "target": "WindowCovering.DownOrClose",
            "args": {}
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 3600000,
    "script": "(#WindowCovering #LivingRoom #Blind).windowCovering_upOrOpen()\n(#WindowCovering #LivingRoom #Blind).windowCovering_downOrClose()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 3600000,\n  \"script\": \"(#WindowCovering #LivingRoom #Blind).windowCovering_upOrOpen()\n(#WindowCovering #LivingRoom #Blind).windowCovering_downOrClose()\"\n}"
}