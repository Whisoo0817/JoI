{
  "command_eng": "If it is raining and the living room window is open, close the window and set the dehumidifier to dehumidifying mode.",
  "connected_devices": {
    "Outdoor_Rain": {
      "category": [
        "RainSensor"
      ],
      "tags": [
        "Outdoor",
        "RainSensor"
      ]
    },
    "Garden_Rain": {
      "category": [
        "RainSensor"
      ],
      "tags": [
        "Garden",
        "RainSensor"
      ]
    },
    "LivingRoom_Window": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "LivingRoom",
        "Window",
        "WindowCovering"
      ]
    },
    "Bedroom_Window": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Bedroom",
        "Window",
        "WindowCovering"
      ]
    },
    "Living_Dehum": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "Living",
        "Dehumidifier"
      ]
    },
    "Bedroom_Dehum": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "Bedroom",
        "Dehumidifier"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "RainSensor.Rain == true and WindowCovering.CurrentPosition > 0",
        "then": [
          {
            "op": "call",
            "target": "WindowCovering.DownOrClose",
            "args": {}
          },
          {
            "op": "call",
            "target": "Dehumidifier.SetDehumidifierMode",
            "args": {
              "Mode": "dehumidifying"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#RainSensor).rainSensor_rain == true and (#WindowCovering #LivingRoom #Window).windowCovering_currentPosition > 0) {\n(#WindowCovering #LivingRoom #Window).windowCovering_downOrClose()\n(#Dehumidifier).dehumidifier_setDehumidifierMode(\"dehumidifying\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#RainSensor).rainSensor_rain == true and (#WindowCovering #LivingRoom #Window).windowCovering_currentPosition > 0) {\n(#WindowCovering #LivingRoom #Window).windowCovering_downOrClose()\n(#Dehumidifier).dehumidifier_setDehumidifierMode(\\\"dehumidifying\\\")\\n}\"\n}"
}