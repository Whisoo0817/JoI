{
  "command_eng": "If the oven is in grill mode, add 4 more minutes.",
  "connected_devices": {
    "Kitchen_Oven": {
      "category": [
        "Oven"
      ],
      "tags": [
        "Oven",
        "Kitchen"
      ]
    },
    "Bakery_Oven": {
      "category": [
        "Oven"
      ],
      "tags": [
        "Oven",
        "Bakery"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "Oven.OvenMode == \"grill\"",
        "then": [
          {
            "op": "call",
            "target": "Oven.AddMoreTime",
            "args": {
              "Time": 240.0
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Oven).oven_ovenMode == \"grill\") {\n(#Oven).oven_addMoreTime(240.0)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Oven).oven_ovenMode == \\\"grill\\\") {\\n(#Oven).oven_addMoreTime(240.0)\\n}\"\n}"
}