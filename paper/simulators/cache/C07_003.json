{
  "command_eng": "When the sound sensor value exceeds 50, stop speaker playback.",
  "connected_devices": {
    "LivingRoom_Sound": {
      "category": [
        "SoundSensor"
      ],
      "tags": [
        "LivingRoom",
        "SoundSensor"
      ]
    },
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Kitchen_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Kitchen",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "SoundSensor.Sound > 50",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Speaker.Stop",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#SoundSensor #LivingRoom).soundSensor_sound > 50)\n(#Speaker).speaker_stop()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#SoundSensor #LivingRoom).soundSensor_sound > 50)\n(#Speaker).speaker_stop()\"\n}"
}