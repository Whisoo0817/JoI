{
  "command_eng": "If the pressure is 100 or higher and no one is home, close the valve and sound emergency siren.",
  "connected_devices": {
    "Main_Pressure": {
      "category": [
        "PressureSensor"
      ],
      "tags": [
        "Main",
        "PressureSensor"
      ]
    },
    "Garden_Pressure": {
      "category": [
        "PressureSensor"
      ],
      "tags": [
        "Garden",
        "PressureSensor"
      ]
    },
    "Living_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Living",
        "PresenceSensor"
      ]
    },
    "Bedroom_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Bedroom",
        "PresenceSensor"
      ]
    },
    "Main_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Main",
        "Valve"
      ]
    },
    "Garden_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Garden",
        "Valve"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    },
    "Entrance_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Entrance",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "PressureSensor.Pressure >= 100 && PresenceSensor.Presence == false",
        "then": [
          {
            "op": "call",
            "target": "Valve.Close",
            "args": {}
          },
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "emergency"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#PressureSensor).pressure >= 100 and not (#PresenceSensor).presenceSensor_presence) {\n(#Valve).valve_close()\n(#Siren).siren_setSirenMode(\"emergency\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#PressureSensor).pressure >= 100 and not (#PresenceSensor).presenceSensor_presence) {\n(#Valve).valve_close()\n(#Siren).siren_setSirenMode(\\\"emergency\\\")\\n}\"\n}"
}