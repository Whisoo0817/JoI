{
  "command_eng": "Check every 5 minutes; if the charger is fully charged, turn it off.",
  "connected_devices": {
    "Main_Charger": {
      "category": [
        "Charger",
        "Switch"
      ],
      "tags": [
        "Main",
        "Charger"
      ]
    },
    "Garage_Charger": {
      "category": [
        "Charger",
        "Switch"
      ],
      "tags": [
        "Garage",
        "Charger"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "5 MIN",
        "body": [
          {
            "op": "if",
            "cond": "Charger.ChargingState == \"fullyCharged\"",
            "then": [
              {
                "op": "call",
                "target": "Switch.Off",
                "args": {}
              }
            ],
            "else": []
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 300000,
    "script": "if ((#Charger #Switch).charger_chargingState == \"fullyCharged\") {\n(#Charger #Switch).switch_off()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 300000,\n  \"script\": \"if ((#Charger #Switch).charger_chargingState == \\\"fullyCharged\\\") {\\n(#Charger #Switch).switch_off()\\n}\"\n}"
}