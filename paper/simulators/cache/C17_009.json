{
  "command_eng": "Check all door locks in Sector 1 every hour; if any one is open, change all lights in that sector to red.",
  "connected_devices": {
    "S1_Lock_1": {
      "category": [
        "DoorLock"
      ],
      "tags": [
        "Sector1",
        "DoorLock"
      ]
    },
    "S1_Lock_2": {
      "category": [
        "DoorLock"
      ],
      "tags": [
        "Sector1",
        "DoorLock"
      ]
    },
    "S2_Lock": {
      "category": [
        "DoorLock"
      ],
      "tags": [
        "Sector2",
        "DoorLock"
      ]
    },
    "S1_Light_1": {
      "category": [
        "Light",
        "ColorControl"
      ],
      "tags": [
        "Sector1",
        "Light",
        "ColorControl"
      ]
    },
    "S1_Light_2": {
      "category": [
        "Light",
        "ColorControl"
      ],
      "tags": [
        "Sector1",
        "Light",
        "ColorControl"
      ]
    },
    "S2_Light": {
      "category": [
        "Light",
        "ColorControl"
      ],
      "tags": [
        "Sector2",
        "Light",
        "ColorControl"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 * * * *"
      },
      {
        "op": "if",
        "cond": "DoorLock.DoorLockState == \"open\"",
        "then": [
          {
            "op": "call",
            "target": "Light.MoveToColor",
            "args": {
              "ColorX": 0.675,
              "ColorY": 0.322,
              "TransitionTime": 0.0
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 * * * *",
    "period": 0,
    "script": "if (all(#DoorLock #Sector1).doorLock_doorLockState == \"open\") {\nall(#Light #Sector1).light_moveToColor(0.675, 0.322, 0.0)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 * * * *\",\n  \"period\": 0,\n  \"script\": \"if (all(#DoorLock #Sector1).doorLock_doorLockState == \\\"open\\\") {\\nall(#Light #Sector1).light_moveToColor(0.675, 0.322, 0.0)\\n}\"\n}"
}