{
  "command_eng": "Every 10 PM, if presence is detected in the living room, turn on all lights.",
  "connected_devices": {
    "LR_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "LivingRoom",
        "PresenceSensor"
      ]
    },
    "Bedroom_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Bedroom",
        "PresenceSensor"
      ]
    },
    "LR_Light": {
      "category": [
        "Light",
        "Switch",
        "LevelControl"
      ],
      "tags": [
        "LivingRoom",
        "Light",
        "Switch",
        "LevelControl"
      ]
    },
    "Kitchen_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Kitchen",
        "Light",
        "Switch"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 22 * * *"
      },
      {
        "op": "if",
        "cond": "PresenceSensor.Presence == true",
        "then": [
          {
            "op": "call",
            "target": "Switch.On",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 22 * * *",
    "period": 0,
    "script": "if ((#PresenceSensor #LivingRoom).presenceSensor_presence == true) {\nall(#Light #Switch #LivingRoom).switch_on()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 22 * * *\",\n  \"period\": 0,\n  \"script\": \"if ((#PresenceSensor #LivingRoom).presenceSensor_presence == true) {\nall(#Light #Switch #LivingRoom).switch_on()\n}\"\n}"
}