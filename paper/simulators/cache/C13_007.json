{
  "command_eng": "Every hour, alternate the air conditioner's target temperature between 25 and 20 degrees.",
  "connected_devices": {
    "MR_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "MeetingRoom",
        "AirConditioner"
      ]
    },
    "LR_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "LivingRoom",
        "AirConditioner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 * * * *"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "1 HOUR",
        "body": [
          {
            "op": "call",
            "target": "AirConditioner.SetTargetTemperature",
            "args": {
              "Temperature": 25.0
            }
          },
          {
            "op": "delay",
            "duration": "1 HOUR"
          },
          {
            "op": "call",
            "target": "AirConditioner.SetTargetTemperature",
            "args": {
              "Temperature": 20.0
            }
          },
          {
            "op": "delay",
            "duration": "1 HOUR"
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 * * * *",
    "period": 3600000,
    "script": "state := \"25\"\nif (state == \"25\") {\n(#AirConditioner).airConditioner_setTargetTemperature(25.0)\n    state = \"20\"\n}\nelse {\n(#AirConditioner).airConditioner_setTargetTemperature(20.0)\n    state = \"25\"\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 * * * *\",\n  \"period\": 3600000,\n  \"script\": \"state := \\\"25\\\"\\nif (state == \\\"25\\\") {\\n(#AirConditioner).airConditioner_setTargetTemperature(25.0)\\n    state = \\\"20\\\"\\n}\\nelse {\\n(#AirConditioner).airConditioner_setTargetTemperature(20.0)\\n    state = \\\"25\\\"\\n}\"\n}"
}