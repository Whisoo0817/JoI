    "Kitchen_Valve_Gas": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Kitchen",
        "Valve"
      ]
    },
    "Kitchen_Valve_Water": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Kitchen",
        "Valve"
      ]
    },
    "Garden_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Garden",
        "Valve"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "call",
        "target": "Valve.Open",
        "args": {}
      },
      {
        "op": "delay",
        "duration": "5 MIN"
      },
      {
        "op": "call",
        "target": "Valve.Close",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "all(#Valve #Kitchen).valve_open()\ndelay(5 MIN)\nall(#Valve #Kitchen).valve_close()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"all(#Valve #Kitchen).valve_open()\ndelay(5 MIN)\nall(#Valve #Kitchen).valve_close()\"\n}"
