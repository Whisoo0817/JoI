{
  "command_eng": "Every hour on Christmas, play 'Christmas.mp3' through the speaker.",
  "connected_devices": {
    "Living_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Living",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 * 12-25 * 12"
      },
      {
        "op": "call",
        "target": "Speaker.Play",
        "args": {
          "MediaSource": "Christmas.mp3"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 * 12-25 * 12",
    "period": 0,
    "script": "(#Speaker).speaker_play(\"Christmas.mp3\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 * 12-25 * 12\",\n  \"period\": 0,\n  \"script\": \"(#Speaker).speaker_play(\\\"Christmas.mp3\\\")\"\n}"
}