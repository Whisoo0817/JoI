{
  "command_eng": "When the contact sensor is closed, sound the police siren every 10 seconds thereafter.",
  "connected_devices": {
    "Entrance_Contact": {
      "category": [
        "ContactSensor"
      ],
      "tags": [
        "Entrance",
        "ContactSensor"
      ]
    },
    "Garage_Contact": {
      "category": [
        "ContactSensor"
      ],
      "tags": [
        "Garage",
        "ContactSensor"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    },
    "Entrance_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Entrance",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "ContactSensor.Contact == true",
        "edge": "none"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "10 SEC",
        "body": [
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "police"
            }
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 10000,
    "script": "phase := 0\nif (phase == 0) {\nwait until((#ContactSensor).contactSensor_contact == true)\n    phase = 1\n    (#Siren).siren_setSirenMode(\"police\")\n}\nelse {\n(#Siren).siren_setSirenMode(\"police\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 10000,\n  \"script\": \"phase := 0\nif (phase == 0) {\nwait until((#ContactSensor).contactSensor_contact == true)\n    phase = 1\n    (#Siren).siren_setSirenMode(\\\"police\\\")\\n}\\nelse {\\n(#Siren).siren_setSirenMode(\\\"police\\\")\\n}\"\n}"
}