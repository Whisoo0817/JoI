{
  "command_eng": "When the presence sensor detects someone, turn on the TV.",
  "connected_devices": {
    "LivingRoom_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "LivingRoom",
        "PresenceSensor"
      ]
    },
    "LivingRoom_TV": {
      "category": [
        "Television",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "Television",
        "Switch"
      ]
    },
    "Bedroom_TV": {
      "category": [
        "Television",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "Television",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "PresenceSensor.Presence == true",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Switch.On",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#PresenceSensor #LivingRoom).presenceSensor_presence == true)\n(#Television #Switch).switch_on()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#PresenceSensor #LivingRoom).presenceSensor_presence == true)\n(#Television #Switch).switch_on()\"\n}"
}