{
  "command_eng": "Set the speaker volume to 20 and increase it to 40 after 10 minutes.",
  "connected_devices": {
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "call",
        "target": "Speaker.SetVolume",
        "args": {
          "Volume": 20
        }
      },
      {
        "op": "delay",
        "duration": "10 MIN"
      },
      {
        "op": "call",
        "target": "Speaker.SetVolume",
        "args": {
          "Volume": 20
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "(#Speaker).speaker_setVolume(20)\ndelay(10 MIN)\n(#Speaker).speaker_setVolume(20)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"(#Speaker).speaker_setVolume(20)\ndelay(10 MIN)\n(#Speaker).speaker_setVolume(20)\"\n}"
}