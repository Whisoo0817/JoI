{
  "command_eng": "Output the charger's power consumption through the speaker.",
  "connected_devices": {
    "LivingRoom_Charger": {
      "category": [
        "Charger"
      ],
      "tags": [
        "LivingRoom",
        "Charger"
      ]
    },
    "Bedroom_Charger": {
      "category": [
        "Charger"
      ],
      "tags": [
        "Bedroom",
        "Charger"
      ]
    },
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Kitchen_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Kitchen",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "read",
        "var": "Power",
        "src": "Charger.Power"
      },
      {
        "op": "call",
        "target": "Speaker.Speak",
        "args": {
          "Text": "The charger's power consumption is $Power"
        },
        "var": "Power"
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "Power = (#Charger).charger_power\n(#Speaker).speaker_speak(\"The charger's power consumption is \" + Power)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"Power = (#Charger).charger_power\n(#Speaker).speaker_speak(\\\"The charger's power consumption is \\\" + Power)\"\n}"
}