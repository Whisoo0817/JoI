{
  "command_eng": "If a water leak is detected in the basement and the main valve is open, close all main valves and sound the police siren.",
  "connected_devices": {
    "Basement_Leak": {
      "category": [
        "LeakSensor"
      ],
      "tags": [
        "Basement",
        "LeakSensor"
      ]
    },
    "Garage_Leak": {
      "category": [
        "LeakSensor"
      ],
      "tags": [
        "Garage",
        "LeakSensor"
      ]
    },
    "Main_Valve_1": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Main",
        "Valve"
      ]
    },
    "Main_Valve_2": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Main",
        "Valve"
      ]
    },
    "Garden_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Garden",
        "Valve"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    },
    "Garage_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Garage",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "LeakSensor.Leakage == true and Valve.ValveState == true",
        "then": [
          {
            "op": "call",
            "target": "Valve.Close",
            "args": {}
          },
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "police"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#LeakSensor #Basement).leakSensor_leakage == true and all(#Valve #Main).valve_valveState == true) {\nall(#Valve #Main).valve_close()\n(#Siren).siren_setSirenMode(\"police\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#LeakSensor #Basement).leakSensor_leakage == true and all(#Valve #Main).valve_valveState == true) {\nall(#Valve #Main).valve_close()\n(#Siren).siren_setSirenMode(\\\"police\\\")\\n}\"\n}"
}