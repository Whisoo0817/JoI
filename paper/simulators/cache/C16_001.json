{
  "command_eng": "On weekends at 3 PM, check for leakage; if detected, set the siren to emergency mode.",
  "connected_devices": {
    "Basement_Leak": {
      "category": [
        "LeakSensor"
      ],
      "tags": [
        "Basement",
        "LeakSensor"
      ]
    },
    "Kitchen_Leak": {
      "category": [
        "LeakSensor"
      ],
      "tags": [
        "Kitchen",
        "LeakSensor"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    },
    "Entrance_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Entrance",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 15 * * 6,7"
      },
      {
        "op": "if",
        "cond": "LeakSensor.Leakage == true",
        "then": [
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "emergency"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 15 * * 6,7",
    "period": 0,
    "script": "if (all(#LeakSensor).leakSensor_leakage ==| true) {\n(#Siren).siren_setSirenMode(\"emergency\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 15 * * 6,7\",\n  \"period\": 0,\n  \"script\": \"if (all(#LeakSensor).leakSensor_leakage ==| true) {\n(#Siren).siren_setSirenMode(\\\"emergency\\\")\\n}\"\n}"
}