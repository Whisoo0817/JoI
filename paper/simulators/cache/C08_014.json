{
  "command_eng": "If button 1 of the multi-button is pressed and motion is detected in the bedroom, turn on the bedroom light at maximum brightness.",
  "connected_devices": {
    "Bedroom_MB": {
      "category": [
        "MultiButton"
      ],
      "tags": [
        "Bedroom",
        "MultiButton"
      ]
    },
    "LR_MB": {
      "category": [
        "MultiButton"
      ],
      "tags": [
        "LivingRoom",
        "MultiButton"
      ]
    },
    "Bedroom_MS": {
      "category": [
        "MotionSensor"
      ],
      "tags": [
        "Bedroom",
        "MotionSensor"
      ]
    },
    "Hall_MS": {
      "category": [
        "MotionSensor"
      ],
      "tags": [
        "Hallway",
        "MotionSensor"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light"
      ],
      "tags": [
        "Bedroom",
        "Light"
      ]
    },
    "LR_Light": {
      "category": [
        "Light"
      ],
      "tags": [
        "LivingRoom",
        "Light"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "MultiButton.Button1 == \"pushed\" and MotionSensor.Motion == true",
        "then": [
          {
            "op": "call",
            "target": "Light.MoveToBrightness",
            "args": {
              "Brightness": 100.0,
              "Rate": 0.0
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#MultiButton).multiButton_button1 == \"pushed\" and (#MotionSensor #Bedroom).motionSensor_motion == true) {\n(#Light #Bedroom).light_moveToBrightness(100.0, 0.0)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#MultiButton).multiButton_button1 == \\\"pushed\\\" and (#MotionSensor #Bedroom).motionSensor_motion == true) {\\n(#Light #Bedroom).light_moveToBrightness(100.0, 0.0)\\n}\"\n}"
}