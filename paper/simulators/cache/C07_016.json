{
  "command_eng": "When the fine dust level in the study reaches 30 or higher, turn on the study air purifier.",
  "connected_devices": {
    "Study_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Study",
        "AirQualitySensor"
      ]
    },
    "LivingRoom_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "LivingRoom",
        "AirQualitySensor"
      ]
    },
    "Study_AP": {
      "category": [
        "AirPurifier",
        "Switch"
      ],
      "tags": [
        "Study",
        "AirPurifier",
        "Switch"
      ]
    },
    "Bedroom_AP": {
      "category": [
        "AirPurifier",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "AirPurifier",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "AirQualitySensor.FineDustLevel >= 30",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Switch.On",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#AirQualitySensor #Study).airQualitySensor_fineDustLevel >= 30)\n(#AirPurifier #Switch #Study).switch_on()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#AirQualitySensor #Study).airQualitySensor_fineDustLevel >= 30)\n(#AirPurifier #Switch #Study).switch_on()\"\n}"
}