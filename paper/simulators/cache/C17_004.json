{
  "command_eng": "Check every 30 minutes; if the temperature is 30 degrees or higher, set the target temperature to 25 degrees; if it's below 23 degrees, set it to 26 degrees.",
  "connected_devices": {
    "Living_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Living",
        "TemperatureSensor"
      ]
    },
    "Bedroom_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Bedroom",
        "TemperatureSensor"
      ]
    },
    "Living_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Living",
        "AirConditioner"
      ]
    },
    "Bedroom_AC": {
      "category": [
        "AirConditioner"
      ],
      "tags": [
        "Bedroom",
        "AirConditioner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "30 MIN",
        "body": [
          {
            "op": "if",
            "cond": "TemperatureSensor.Temperature >= 30",
            "then": [
              {
                "op": "call",
                "target": "AirConditioner.SetTargetTemperature",
                "args": {
                  "Temperature": 25.0
                }
              }
            ],
            "else": [
              {
                "op": "if",
                "cond": "TemperatureSensor.Temperature < 23",
                "then": [
                  {
                    "op": "call",
                    "target": "AirConditioner.SetTargetTemperature",
                    "args": {
                      "Temperature": 25.0
                    }
                  }
                ],
                "else": []
              }
            ]
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 1800000,
    "script": "if ((#TemperatureSensor).temperatureSensor_temperature >= 30) {\n(#AirConditioner).airConditioner_setTargetTemperature(25.0)\n}\nelse {\nif ((#TemperatureSensor).temperatureSensor_temperature < 23) {\n(#AirConditioner).airConditioner_setTargetTemperature(25.0)\n}\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 1800000,\n  \"script\": \"if ((#TemperatureSensor).temperatureSensor_temperature >= 30) {\n(#AirConditioner).airConditioner_setTargetTemperature(25.0)\n}\nelse {\nif ((#TemperatureSensor).temperatureSensor_temperature < 23) {\n(#AirConditioner).airConditioner_setTargetTemperature(25.0)\n}\n}\"\n}"
}