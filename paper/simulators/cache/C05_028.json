{
  "command_eng": "If the warehouse fine dust level is 100 or higher and the air purifier is in auto mode, switch it to high mode and say through the warehouse speaker \"Switching to high mode\".",
  "connected_devices": {
    "Warehouse_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Warehouse",
        "AirQualitySensor"
      ]
    },
    "Office_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Office",
        "AirQualitySensor"
      ]
    },
    "Warehouse_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Warehouse",
        "AirPurifier"
      ]
    },
    "Office_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Office",
        "AirPurifier"
      ]
    },
    "Warehouse_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Warehouse",
        "Speaker"
      ]
    },
    "Office_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Office",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "AirQualitySensor.FineDustLevel >= 100 and AirPurifier.AirPurifierMode == \"auto\"",
        "then": [
          {
            "op": "call",
            "target": "AirPurifier.SetAirPurifierMode",
            "args": {
              "Mode": "high"
            }
          },
          {
            "op": "call",
            "target": "Speaker.Speak",
            "args": {
              "Text": "Switching to high mode"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#AirQualitySensor #Warehouse).airQualitySensor_fineDustLevel >= 100 and (#AirPurifier #Warehouse).airPurifier_airPurifierMode == \"auto\") {\n(#AirPurifier #Warehouse).airPurifier_setAirPurifierMode(\"high\")\n(#Speaker #Warehouse).speaker_speak(\"Switching to high mode\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#AirQualitySensor #Warehouse).airQualitySensor_fineDustLevel >= 100 and (#AirPurifier #Warehouse).airPurifier_airPurifierMode == \\\"auto\\\") {\\n(#AirPurifier #Warehouse).airPurifier_setAirPurifierMode(\\\"high\\\")\\n(#Speaker #Warehouse).speaker_speak(\\\"Switching to high mode\\\")\\n}\"\n}"
}