{
  "command_eng": "If motion is detected in the garage and the main siren is off, sound the siren in emergency and take a picture.",
  "connected_devices": {
    "Garage_Motion": {
      "category": [
        "MotionSensor"
      ],
      "tags": [
        "Garage",
        "MotionSensor"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "Main",
        "Siren",
        "Switch"
      ]
    },
    "Garage_Camera": {
      "category": [
        "Camera"
      ],
      "tags": [
        "Garage",
        "Camera"
      ]
    },
    "Hallway_Camera": {
      "category": [
        "Camera"
      ],
      "tags": [
        "Hallway",
        "Camera"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "MotionSensor.Motion == true && Siren.SirenMode != \"emergency\"",
        "then": [
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "emergency"
            }
          },
          {
            "op": "call",
            "target": "Camera.CaptureImage",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Garage #MotionSensor).motionSensor_motion == true and (#Siren).siren_sirenMode != \"emergency\") {\n(#Siren).siren_setSirenMode(\"emergency\")\n(#Garage #Camera).camera_captureImage()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Garage #MotionSensor).motionSensor_motion == true and (#Siren).siren_sirenMode != \\\"emergency\\\") {\\n(#Siren).siren_setSirenMode(\\\"emergency\\\")\\n(#Garage #Camera).camera_captureImage()\\n}\"\n}"
}