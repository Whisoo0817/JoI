{
  "command_eng": "When button 2 of the multi-button is pressed, turn on all living room lights and dim them to 30% after 30 minutes.",
  "connected_devices": {
    "LR_MB": {
      "category": [
        "MultiButton"
      ],
      "tags": [
        "LivingRoom",
        "MultiButton"
      ]
    },
    "Bedroom_MB": {
      "category": [
        "MultiButton"
      ],
      "tags": [
        "Bedroom",
        "MultiButton"
      ]
    },
    "LR_Light_1": {
      "category": [
        "Light"
      ],
      "tags": [
        "LivingRoom",
        "Light"
      ]
    },
    "LR_Light_2": {
      "category": [
        "Light"
      ],
      "tags": [
        "LivingRoom",
        "Light"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light"
      ],
      "tags": [
        "Bedroom",
        "Light"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "MultiButton.Button2 == \"pushed\"",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Light.MoveToBrightness",
        "args": {
          "Brightness": 100.0,
          "Rate": 0.0
        }
      },
      {
        "op": "delay",
        "duration": "30 MIN"
      },
      {
        "op": "call",
        "target": "Light.MoveToBrightness",
        "args": {
          "Brightness": 30.0,
          "Rate": 0.0
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#MultiButton #LivingRoom).multiButton_button2 == \"pushed\")\nall(#Light #LivingRoom).light_moveToBrightness(100.0, 0.0)\ndelay(30 MIN)\nall(#Light #LivingRoom).light_moveToBrightness(30.0, 0.0)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#MultiButton #LivingRoom).multiButton_button2 == \\\"pushed\\\")\\nall(#Light #LivingRoom).light_moveToBrightness(100.0, 0.0)\\ndelay(30 MIN)\\nall(#Light #LivingRoom).light_moveToBrightness(30.0, 0.0)\"\n}"
}