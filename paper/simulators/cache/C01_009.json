{
  "command_eng": "Tell me the outdoor temperature through the speaker.",
  "connected_devices": {
    "System_WeatherProvider": {
      "category": [
        "WeatherProvider"
      ],
      "tags": [
        "WeatherProvider"
      ]
    },
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Kitchen_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Kitchen",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "read",
        "var": "TemperatureWeather",
        "src": "WeatherProvider.TemperatureWeather"
      },
      {
        "op": "call",
        "target": "Speaker.Speak",
        "args": {
          "Text": "The outdoor temperature is $TemperatureWeather"
        },
        "var": "TemperatureWeather"
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "TemperatureWeather = (#WeatherProvider).weatherProvider_temperatureWeather\n(#Speaker).speaker_speak(\"The outdoor temperature is \" + TemperatureWeather)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"TemperatureWeather = (#WeatherProvider).weatherProvider_temperatureWeather\n(#Speaker).speaker_speak(\\\"The outdoor temperature is \\\" + TemperatureWeather)\"\n}"
}