{
  "command_eng": "When the presence sensor detects someone, take a picture after 1 minute.",
  "connected_devices": {
    "Entrance_PresenceSensor": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Entrance",
        "PresenceSensor"
      ]
    },
    "Hallway_PresenceSensor": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Hallway",
        "PresenceSensor"
      ]
    },
    "Entrance_Camera": {
      "category": [
        "Camera"
      ],
      "tags": [
        "Entrance",
        "Camera"
      ]
    },
    "LivingRoom_Camera": {
      "category": [
        "Camera"
      ],
      "tags": [
        "LivingRoom",
        "Camera"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "PresenceSensor.Presence == true",
        "edge": "none"
      },
      {
        "op": "delay",
        "duration": "1 MIN"
      },
      {
        "op": "call",
        "target": "Camera.CaptureImage",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#PresenceSensor).presenceSensor_presence == true)\ndelay(1 MIN)\n(#Camera).camera_captureImage()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#PresenceSensor).presenceSensor_presence == true)\ndelay(1 MIN)\n(#Camera).camera_captureImage()\"\n}"
}