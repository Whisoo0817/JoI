{
  "command_eng": "Every 5 minutes from 1 PM to 3 PM, repeat opening and closing the valve.",
  "connected_devices": {
    "Kitchen_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Kitchen",
        "Valve"
      ]
    },
    "Garden_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Garden",
        "Valve"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 13 * * *"
      },
      {
        "op": "cycle",
        "until": "clock.time >= 1500",
        "period": "5 MIN",
        "body": [
          {
            "op": "call",
            "target": "Valve.Open",
            "args": {}
          },
          {
            "op": "delay",
            "duration": "5 MIN"
          },
          {
            "op": "call",
            "target": "Valve.Close",
            "args": {}
          },
          {
            "op": "delay",
            "duration": "5 MIN"
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 13 * * *",
    "period": 300000,
    "script": "if (clock.time >= 1500) {\nbreak\n}\nstate := \"open\"\nif (state == \"open\") {\n(#Valve).valve_open()\n    state = \"closed\"\n}\nelse {\n(#Valve).valve_close()\n    state = \"open\"\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 13 * * *\",\n  \"period\": 300000,\n  \"script\": \"if (clock.time >= 1500) {\nbreak\n}\nstate := \\\"open\\\"\\nif (state == \\\"open\\\") {\\n(#Valve).valve_open()\\n    state = \\\"closed\\\"\\n}\\nelse {\\n(#Valve).valve_close()\\n    state = \\\"open\\\"\\n}\"\n}"
}