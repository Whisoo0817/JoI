{
  "command_eng": "From 10 PM to midnight every 10 minutes, sound the emergency siren.",
  "connected_devices": {
    "Main_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    },
    "Entrance_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Entrance",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 22 * * *"
      },
      {
        "op": "cycle",
        "until": "clock.time >= 2400",
        "period": "10 MIN",
        "body": [
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "emergency"
            }
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 22 * * *",
    "period": 600000,
    "script": "if (clock.time >= 2400) {\nbreak\n}\n(#Siren).siren_setSirenMode(\"emergency\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 22 * * *\",\n  \"period\": 600000,\n  \"script\": \"if (clock.time >= 2400) {\nbreak\n}\n(#Siren).siren_setSirenMode(\\\"emergency\\\")\"\n}"
}