{
  "command_eng": "When the door opens, make the speaker speak \"Welcome\" every minute thereafter.",
  "connected_devices": {
    "Entrance_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Entrance",
        "Door"
      ]
    },
    "Garage_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Garage",
        "Door"
      ]
    },
    "Living_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Living",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "Door.DoorState == \"open\"",
        "edge": "none"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "1 MIN",
        "body": [
          {
            "op": "call",
            "target": "Speaker.Speak",
            "args": {
              "Text": "Welcome"
            }
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 60000,
    "script": "phase := 0\nif (phase == 0) {\nwait until((#Door).door_doorState == \"open\")\n    phase = 1\n    (#Speaker).speaker_speak(\"Welcome\")\n}\nelse {\n(#Speaker).speaker_speak(\"Welcome\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 60000,\n  \"script\": \"phase := 0\nif (phase == 0) {\nwait until((#Door).door_doorState == \\\"open\\\")\\n    phase = 1\\n    (#Speaker).speaker_speak(\\\"Welcome\\\")\\n}\\nelse {\\n(#Speaker).speaker_speak(\\\"Welcome\\\")\\n}\"\n}"
}