{
  "command_eng": "If the motion is detected in the guest room and the air conditioner is off, set the air conditioner to auto mode and set the target temperature to 24.",
  "connected_devices": {
    "GuestRoom_Motion": {
      "category": [
        "MotionSensor"
      ],
      "tags": [
        "GuestRoom",
        "MotionSensor"
      ]
    },
    "Bedroom_Motion": {
      "category": [
        "MotionSensor"
      ],
      "tags": [
        "Bedroom",
        "MotionSensor"
      ]
    },
    "GuestRoom_AC": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "GuestRoom",
        "AirConditioner",
        "Switch"
      ]
    },
    "Bedroom_AC": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "AirConditioner",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "MotionSensor.Motion == true && AirConditioner.AirConditionerMode != \"auto\"",
        "then": [
          {
            "op": "call",
            "target": "AirConditioner.SetAirConditionerMode",
            "args": {
              "Mode": "auto"
            }
          },
          {
            "op": "call",
            "target": "AirConditioner.SetTargetTemperature",
            "args": {
              "Temperature": 24
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#GuestRoom #MotionSensor).motionSensor_motion == true and (#GuestRoom #AirConditioner).airConditioner_airConditionerMode != \"auto\") {\n(#GuestRoom #AirConditioner).airConditioner_setAirConditionerMode(\"auto\")\n(#GuestRoom #AirConditioner).airConditioner_setTargetTemperature(24)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#GuestRoom #MotionSensor).motionSensor_motion == true and (#GuestRoom #AirConditioner).airConditioner_airConditionerMode != \\\"auto\\\") {\\n(#GuestRoom #AirConditioner).airConditioner_setAirConditionerMode(\\\"auto\\\")\\n(#GuestRoom #AirConditioner).airConditioner_setTargetTemperature(24)\\n}\"\n}"
}