{
  "command_eng": "If the pump is in normal mode, set it to maximum mode.",
  "connected_devices": {
    "Main_Pump": {
      "category": [
        "Pump"
      ],
      "tags": [
        "Main",
        "Pump"
      ]
    },
    "Garage_Pump": {
      "category": [
        "Pump"
      ],
      "tags": [
        "Garage",
        "Pump"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "read",
        "var": "currentMode",
        "src": "Pump.PumpMode"
      },
      {
        "op": "if",
        "cond": "currentMode == \"normal\"",
        "then": [
          {
            "op": "call",
            "target": "Pump.SetPumpMode",
            "args": {
              "PumpMode": "maximum"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "currentMode = (#Pump).pump_pumpMode\nif (currentMode == \"normal\") {\n(#Pump).pump_setPumpMode(\"maximum\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"currentMode = (#Pump).pump_pumpMode\nif (currentMode == \\\"normal\\\") {\\n(#Pump).pump_setPumpMode(\\\"maximum\\\")\\n}\"\n}"
}