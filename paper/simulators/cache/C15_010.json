{
  "command_eng": "At 6 PM every day, announce the dinner menu of the student cafeteria through the speaker.",
  "connected_devices": {
    "Main_MenuProvider": {
      "category": [
        "MenuProvider"
      ],
      "tags": [
        "Main",
        "MenuProvider"
      ]
    },
    "Office_MenuProvider": {
      "category": [
        "MenuProvider"
      ],
      "tags": [
        "Office",
        "MenuProvider"
      ]
    },
    "Living_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Living",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 18 * * *"
      },
      {
        "op": "call",
        "target": "MenuProvider.GetMenu",
        "args": {
          "Command": "오늘 학생식당 저녁"
        },
        "var": "GetMenu"
      },
      {
        "op": "call",
        "target": "Speaker.Speak",
        "args": {
          "Text": "$GetMenu"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 18 * * *",
    "period": 0,
    "script": "GetMenu = (#MenuProvider).menuProvider_getMenu(\"오늘 학생식당 저녁\")\n(#Speaker).speaker_speak(GetMenu)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 18 * * *\",\n  \"period\": 0,\n  \"script\": \"GetMenu = (#MenuProvider).menuProvider_getMenu(\\\"오늘 학생식당 저녁\\\")\\n(#Speaker).speaker_speak(GetMenu)\"\n}"
}