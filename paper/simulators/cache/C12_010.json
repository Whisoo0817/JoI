{
  "command_eng": "When the server rack humidity becomes higher than 70%, set the lab dehumidifier to dehumidifying mode and check the humidity every hour; turn it off if it's below 50%.",
  "connected_devices": {
    "SR_Humid": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "ServerRack",
        "HumiditySensor"
      ]
    },
    "Lab_Humid": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Lab",
        "HumiditySensor"
      ]
    },
    "Lab_Dehum": {
      "category": [
        "Dehumidifier",
        "Switch"
      ],
      "tags": [
        "Lab",
        "Dehumidifier",
        "Switch"
      ]
    },
    "Office_Dehum": {
      "category": [
        "Dehumidifier",
        "Switch"
      ],
      "tags": [
        "Office",
        "Dehumidifier",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "HumiditySensor.Humidity > 70",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Dehumidifier.SetDehumidifierMode",
        "args": {
          "Mode": "dehumidifying"
        }
      },
      {
        "op": "cycle",
        "until": null,
        "period": "1 HOUR",
        "body": [
          {
            "op": "if",
            "cond": "HumiditySensor.Humidity < 50",
            "then": [
              {
                "op": "call",
                "target": "Switch.Off",
                "args": {}
              }
            ],
            "else": []
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 3600000,
    "script": "phase := 0\nif (phase == 0) {\nwait until((#HumiditySensor #ServerRack).humiditySensor_humidity > 70)\n    phase = 1\n    (#Dehumidifier #Lab).dehumidifier_setDehumidifierMode(\"dehumidifying\")\n}\nelse {\nif ((#HumiditySensor #ServerRack).humiditySensor_humidity < 50) {\n(#Dehumidifier #Switch #Lab).switch_off()\n}\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 3600000,\n  \"script\": \"phase := 0\nif (phase == 0) {\nwait until((#HumiditySensor #ServerRack).humiditySensor_humidity > 70)\n    phase = 1\n    (#Dehumidifier #Lab).dehumidifier_setDehumidifierMode(\\\"dehumidifying\\\")\\n}\\nelse {\\nif ((#HumiditySensor #ServerRack).humiditySensor_humidity < 50) {\\n(#Dehumidifier #Switch #Lab).switch_off()\\n}\\n}\"\n}"
}