{
  "command_eng": "On weekdays at 7 AM, start the rice cooker in auto-cleaning mode.",
  "connected_devices": {
    "Kitchen_RiceCooker": {
      "category": [
        "RiceCooker"
      ],
      "tags": [
        "Kitchen",
        "RiceCooker"
      ]
    },
    "Dining_RiceCooker": {
      "category": [
        "RiceCooker"
      ],
      "tags": [
        "Dining",
        "RiceCooker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 7 * * 1-5"
      },
      {
        "op": "call",
        "target": "RiceCooker.SetRiceCookerMode",
        "args": {
          "Mode": "autoClean"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 7 * * 1-5",
    "period": 0,
    "script": "(#RiceCooker).riceCooker_setRiceCookerMode(\"autoClean\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 7 * * 1-5\",\n  \"period\": 0,\n  \"script\": \"(#RiceCooker).riceCooker_setRiceCookerMode(\\\"autoClean\\\")\"\n}"
}