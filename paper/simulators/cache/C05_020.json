{
  "command_eng": "If the bathroom humidity is 85% or higher and the bathroom door is closed, turn on the light and open the door.",
  "connected_devices": {
    "Bathroom_Hum": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Bathroom",
        "HumiditySensor"
      ]
    },
    "Bedroom_Hum": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Bedroom",
        "HumiditySensor"
      ]
    },
    "Bathroom_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Bathroom",
        "Door"
      ]
    },
    "Bedroom_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Bedroom",
        "Door"
      ]
    },
    "Bathroom_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Bathroom",
        "Light",
        "Switch"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "HumiditySensor.Humidity >= 85 and Door.DoorState == \"closed\"",
        "then": [
          {
            "op": "call",
            "target": "Light.MoveToBrightness",
            "args": {
              "Brightness": 100.0,
              "Rate": 0.0
            }
          },
          {
            "op": "call",
            "target": "Door.Open",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#HumiditySensor #Bathroom).humiditySensor_humidity >= 85 and (#Door #Bathroom).door_doorState == \"closed\") {\n(#Light #Bathroom).light_moveToBrightness(100.0, 0.0)\n(#Door #Bathroom).door_open()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#HumiditySensor #Bathroom).humiditySensor_humidity >= 85 and (#Door #Bathroom).door_doorState == \\\"closed\\\") {\\n(#Light #Bathroom).light_moveToBrightness(100.0, 0.0)\\n(#Door #Bathroom).door_open()\\n}\"\n}"
}