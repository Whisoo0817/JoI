{
  "command_eng": "If the bathroom humidity is 85% or higher and the bathroom door is closed, turn on the light and open the door.",
  "connected_devices": {
    "Bathroom_Hum": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Bathroom",
        "HumiditySensor"
      ]
    },
    "Bedroom_Hum": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Bedroom",
        "HumiditySensor"
      ]
    },
    "Bathroom_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Bathroom",
        "Door"
      ]
    },
    "Bedroom_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Bedroom",
        "Door"
      ]
    },
    "Bathroom_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Bathroom",
        "Light",
        "Switch"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "HumiditySensor.Humidity >= 85 && Door.DoorState == \"closed\"",
        "then": [
          {
            "op": "call",
            "target": "Switch.On",
            "args": {}
          },
          {
            "op": "call",
            "target": "Door.Open",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Bathroom #HumiditySensor).humiditySensor_humidity >= 85 and (#Bathroom #Door).door_doorState == \"closed\") {\n(#Bathroom #Light).switch_on()\n(#Bathroom #Door).door_open()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Bathroom #HumiditySensor).humiditySensor_humidity >= 85 and (#Bathroom #Door).door_doorState == \\\"closed\\\") {\\n(#Bathroom #Light).switch_on()\\n(#Bathroom #Door).door_open()\\n}\"\n}"
}