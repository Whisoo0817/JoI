{
  "command_eng": "Repeat opening and closing the window every 10 minutes.",
  "connected_devices": {
    "Main_Window": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Main",
        "Window",
        "WindowCovering"
      ]
    },
    "Bedroom_Window": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Bedroom",
        "Window",
        "WindowCovering"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "10 MIN",
        "body": [
          {
            "op": "call",
            "target": "WindowCovering.UpOrOpen",
            "args": {}
          },
          {
            "op": "delay",
            "duration": "10 MIN"
          },
          {
            "op": "call",
            "target": "WindowCovering.DownOrClose",
            "args": {}
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 600000,
    "script": "(#WindowCovering #Window).windowCovering_upOrOpen()\ndelay(10 MIN)\n(#WindowCovering #Window).windowCovering_downOrClose()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 600000,\n  \"script\": \"(#WindowCovering #Window).windowCovering_upOrOpen()\ndelay(10 MIN)\n(#WindowCovering #Window).windowCovering_downOrClose()\"\n}"
}