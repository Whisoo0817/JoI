{
  "command_eng": "At 8 AM, turn on the high-efficiency tagged air purifier and set it to auto mode.",
  "connected_devices": {
    "HighEfficiency_AirPurifier": {
      "category": [
        "AirPurifier",
        "Switch"
      ],
      "tags": [
        "HighEfficiency",
        "AirPurifier",
        "Switch"
      ]
    },
    "LowEfficiency_AirPurifier": {
      "category": [
        "AirPurifier",
        "Switch"
      ],
      "tags": [
        "LowEfficiency",
        "AirPurifier",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 8 * * *"
      },
      {
        "op": "call",
        "target": "Switch.On",
        "args": {}
      },
      {
        "op": "call",
        "target": "AirPurifier.SetAirPurifierMode",
        "args": {
          "Mode": "auto"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 8 * * *",
    "period": 0,
    "script": "(#AirPurifier #Switch #HighEfficiency).switch_on()\n(#AirPurifier #HighEfficiency).airPurifier_setAirPurifierMode(\"auto\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 8 * * *\",\n  \"period\": 0,\n  \"script\": \"(#AirPurifier #Switch #HighEfficiency).switch_on()\n(#AirPurifier #HighEfficiency).airPurifier_setAirPurifierMode(\\\"auto\\\")\"\n}"
}