{
  "command_eng": "If the wine cellar temperature is 15 degrees or higher and humidity is 60% or higher, turn on the air conditioner and turn off the humidifier.",
  "connected_devices": {
    "WineCellar_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "WineCellar",
        "TemperatureSensor"
      ]
    },
    "Basement_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Basement",
        "TemperatureSensor"
      ]
    },
    "WineCellar_Hum": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "WineCellar",
        "HumiditySensor"
      ]
    },
    "Basement_Hum": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Basement",
        "HumiditySensor"
      ]
    },
    "AC": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "AirConditioner",
        "Switch"
      ]
    },
    "Bedroom_AC": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "AirConditioner",
        "Switch"
      ]
    },
    "WineCellar_Humidifier": {
      "category": [
        "Humidifier",
        "Switch"
      ],
      "tags": [
        "Humidifier",
        "Switch"
      ]
    },
    "Bedroom_Humidifier": {
      "category": [
        "Humidifier",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "Humidifier",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "TemperatureSensor.Temperature >= 15 && HumiditySensor.Humidity >= 60",
        "then": [
          {
            "op": "call",
            "target": "Switch.On",
            "args": {}
          },
          {
            "op": "call",
            "target": "Switch.Off",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#WineCellar #TemperatureSensor).temperatureSensor_temperature >= 15 and (#WineCellar #HumiditySensor).humiditySensor_humidity >= 60) {\n(#AirConditioner).switch_on()\n(#Humidifier).switch_off()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#WineCellar #TemperatureSensor).temperatureSensor_temperature >= 15 and (#WineCellar #HumiditySensor).humiditySensor_humidity >= 60) {\n(#AirConditioner).switch_on()\n(#Humidifier).switch_off()\n}\"\n}"
}