{
  "command_eng": "When it rains, turn on the dehumidifier.",
  "connected_devices": {
    "Outdoor_RainSensor": {
      "category": [
        "RainSensor"
      ],
      "tags": [
        "Outdoor",
        "RainSensor"
      ]
    },
    "Garden_RainSensor": {
      "category": [
        "RainSensor"
      ],
      "tags": [
        "Garden",
        "RainSensor"
      ]
    },
    "LivingRoom_Dehumidifier": {
      "category": [
        "Dehumidifier",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "Dehumidifier",
        "Switch"
      ]
    },
    "Bathroom_Dehumidifier": {
      "category": [
        "Dehumidifier",
        "Switch"
      ],
      "tags": [
        "Bathroom",
        "Dehumidifier",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "RainSensor.Rain == true",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Switch.On",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#RainSensor).rainSensor_rain == true)\n(#Dehumidifier).switch_on()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#RainSensor).rainSensor_rain == true)\n(#Dehumidifier).switch_on()\"\n}"
}