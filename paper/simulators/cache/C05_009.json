{
  "command_eng": "If the fine dust level is 150 or higher and the door is open, close the door and set the air purifier to high.",
  "connected_devices": {
    "Living_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Living",
        "AirQualitySensor"
      ]
    },
    "Bedroom_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Bedroom",
        "AirQualitySensor"
      ]
    },
    "Living_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Living",
        "Door"
      ]
    },
    "Bedroom_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Bedroom",
        "Door"
      ]
    },
    "Living_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Living",
        "AirPurifier"
      ]
    },
    "Bedroom_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Bedroom",
        "AirPurifier"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "AirQualitySensor.FineDustLevel >= 150 and Door.DoorState == \"open\"",
        "then": [
          {
            "op": "call",
            "target": "Door.Close",
            "args": {}
          },
          {
            "op": "call",
            "target": "AirPurifier.SetAirPurifierMode",
            "args": {
              "Mode": "high"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#AirQualitySensor).airQualitySensor_fineDustLevel >= 150 and (#Door).door_doorState == \"open\") {\n(#Door).door_close()\n(#AirPurifier).airPurifier_setAirPurifierMode(\"high\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#AirQualitySensor).airQualitySensor_fineDustLevel >= 150 and (#Door).door_doorState == \\\"open\\\") {\\n(#Door).door_close()\\n(#AirPurifier).airPurifier_setAirPurifierMode(\\\"high\\\")\\n}\"\n}"
}