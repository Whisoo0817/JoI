{
  "command_eng": "Every 7 PM, if no one is detected on the 1st floor, turn off all lights; for the 2nd floor, check at 8 PM and turn off all its lights if no one is present.",
  "connected_devices": {
    "F1_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Floor1",
        "PresenceSensor"
      ]
    },
    "F3_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Floor3",
        "PresenceSensor"
      ]
    },
    "F2_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Floor2",
        "PresenceSensor"
      ]
    },
    "F1_Light_1": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Floor1",
        "Light",
        "Switch"
      ]
    },
    "F1_Light_2": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Floor1",
        "Light",
        "Switch"
      ]
    },
    "F2_Light_1": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Floor2",
        "Light",
        "Switch"
      ]
    },
    "F2_Light_2": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Floor2",
        "Light",
        "Switch"
      ]
    },
    "F3_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Floor3",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 19 * * *"
      },
      {
        "op": "if",
        "cond": "PresenceSensor.Presence == false",
        "then": [
          {
            "op": "call",
            "target": "Light.MoveToBrightness",
            "args": {
              "Brightness": 0.0,
              "Rate": 0.0
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 19 * * *",
    "period": 0,
    "script": "if ((#PresenceSensor #Floor2).presenceSensor_presence == false) {\nall(#Light #Floor2).light_moveToBrightness(0.0, 0.0)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 19 * * *\",\n  \"period\": 0,\n  \"script\": \"if ((#PresenceSensor #Floor2).presenceSensor_presence == false) {\nall(#Light #Floor2).light_moveToBrightness(0.0, 0.0)\n}\"\n}"
}