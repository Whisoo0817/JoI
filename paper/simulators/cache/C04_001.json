{
  "command_eng": "If the audio recorder is recording, stop recording and save as test.mp3; otherwise, start recording.",
  "connected_devices": {
    "Studio_AudioRecorder": {
      "category": [
        "AudioRecorder"
      ],
      "tags": [
        "AudioRecorder",
        "Studio"
      ]
    },
    "Office_AudioRecorder": {
      "category": [
        "AudioRecorder"
      ],
      "tags": [
        "AudioRecorder",
        "Office"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "AudioRecorder.RecordStatus == \"recording\"",
        "then": [
          {
            "op": "call",
            "target": "AudioRecorder.RecordStop",
            "args": {
              "File": "test.mp3"
            }
          }
        ],
        "else": [
          {
            "op": "call",
            "target": "AudioRecorder.RecordStart",
            "args": {}
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#AudioRecorder).audioRecorder_recordStatus == \"recording\") {\n(#AudioRecorder).audioRecorder_recordStop(\"test.mp3\")\n}\nelse {\n(#AudioRecorder).audioRecorder_recordStart()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#AudioRecorder).audioRecorder_recordStatus == \\\"recording\\\") {\\n(#AudioRecorder).audioRecorder_recordStop(\\\"test.mp3\\\")\\n}\\nelse {\\n(#AudioRecorder).audioRecorder_recordStart()\\n}\"\n}"
}