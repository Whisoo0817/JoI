{
  "command_eng": "Check every 5 minutes from 10 PM to 11 PM and turn it off when charging is complete.",
  "connected_devices": {
    "Main_Charger": {
      "category": [
        "Charger",
        "Switch"
      ],
      "tags": [
        "Main",
        "Charger",
        "Switch"
      ]
    },
    "Phone_Charger": {
      "category": [
        "Charger",
        "Switch"
      ],
      "tags": [
        "Phone",
        "Charger",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 22 * * *"
      },
      {
        "op": "cycle",
        "until": "clock.time >= 2300",
        "period": "5 MIN",
        "body": [
          {
            "op": "if",
            "cond": "Charger.ChargingState == \"fullyCharged\"",
            "then": [
              {
                "op": "call",
                "target": "Switch.Off",
                "args": {}
              }
            ],
            "else": []
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 22 * * *",
    "period": 300000,
    "script": "if (clock.time >= 2300) {\nbreak\n}\nif ((#Charger).charger_chargingState == \"fullyCharged\") {\n(#Charger #Switch).switch_off()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 22 * * *\",\n  \"period\": 300000,\n  \"script\": \"if (clock.time >= 2300) {\nbreak\n}\nif ((#Charger).charger_chargingState == \\\"fullyCharged\\\") {\\n(#Charger #Switch).switch_off()\\n}\"\n}"
}