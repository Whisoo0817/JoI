{
  "command_eng": "When button 1 of the multi-button is pressed, turn on the entrance light at maximum brightness.",
  "connected_devices": {
    "Entrance_MB": {
      "category": [
        "MultiButton"
      ],
      "tags": [
        "Entrance",
        "MultiButton"
      ]
    },
    "Hall_MB": {
      "category": [
        "MultiButton"
      ],
      "tags": [
        "Hallway",
        "MultiButton"
      ]
    },
    "Entrance_Light": {
      "category": [
        "Light"
      ],
      "tags": [
        "Entrance",
        "Light"
      ]
    },
    "Hall_Light": {
      "category": [
        "Light"
      ],
      "tags": [
        "Hallway",
        "Light"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "MultiButton.Button1 == \"pushed\"",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Light.MoveToBrightness",
        "args": {
          "Brightness": 100.0,
          "Rate": 0.0
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#MultiButton).multiButton_button1 == \"pushed\")\n(#Light #Entrance).light_moveToBrightness(100.0, 0.0)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#MultiButton).multiButton_button1 == \\\"pushed\\\")\\n(#Light #Entrance).light_moveToBrightness(100.0, 0.0)\"\n}"
}