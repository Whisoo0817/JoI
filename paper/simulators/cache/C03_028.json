{
  "command_eng": "If the baby room sound is 60dB or higher, say \"The baby is crying\" through the living room speaker.",
  "connected_devices": {
    "BabyRoom_Sound": {
      "category": [
        "SoundSensor"
      ],
      "tags": [
        "BabyRoom",
        "SoundSensor"
      ]
    },
    "Bedroom_Sound": {
      "category": [
        "SoundSensor"
      ],
      "tags": [
        "Bedroom",
        "SoundSensor"
      ]
    },
    "Kitchen_Sound": {
      "category": [
        "SoundSensor"
      ],
      "tags": [
        "Kitchen",
        "SoundSensor"
      ]
    },
    "LR_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    },
    "Kitchen_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Kitchen",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "SoundSensor.Sound >= 60",
        "then": [
          {
            "op": "call",
            "target": "Speaker.Speak",
            "args": {
              "Text": "The baby is crying"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#SoundSensor #BabyRoom).soundSensor_sound >= 60) {\n(#Speaker #LivingRoom).speaker_speak(\"The baby is crying\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#SoundSensor #BabyRoom).soundSensor_sound >= 60) {\n(#Speaker #LivingRoom).speaker_speak(\\\"The baby is crying\\\")\\n}\"\n}"
}