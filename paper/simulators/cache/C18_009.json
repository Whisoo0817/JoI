{
  "command_eng": "Every hour from 6 PM to 8 PM, if someone is detected on the 1st floor, turn on all 1st floor lights.",
  "connected_devices": {
    "F1_PresenceSensor": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Floor1",
        "PresenceSensor"
      ]
    },
    "F1_Light_1": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Floor1",
        "Light",
        "Switch"
      ]
    },
    "F1_Light_2": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Floor1",
        "Light",
        "Switch"
      ]
    },
    "F2_PresenceSensor": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Floor2",
        "PresenceSensor"
      ]
    },
    "F2_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Floor2",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 18 * * *"
      },
      {
        "op": "cycle",
        "until": "clock.time >= 2000",
        "period": "1 HOUR",
        "body": [
          {
            "op": "if",
            "cond": "PresenceSensor.Presence == true",
            "then": [
              {
                "op": "call",
                "target": "Light.MoveToBrightness",
                "args": {
                  "Brightness": 100.0,
                  "Rate": 0.0
                }
              }
            ],
            "else": []
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 18 * * *",
    "period": 3600000,
    "script": "if (clock.time >= 2000) {\nbreak\n}\nif ((#PresenceSensor #Floor1).presenceSensor_presence == true) {\nall(#Light #Floor1).light_moveToBrightness(100.0, 0.0)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 18 * * *\",\n  \"period\": 3600000,\n  \"script\": \"if (clock.time >= 2000) {\nbreak\n}\nif ((#PresenceSensor #Floor1).presenceSensor_presence == true) {\nall(#Light #Floor1).light_moveToBrightness(100.0, 0.0)\n}\"\n}"
}