{
  "command_eng": "Output today's weather through the speaker.",
  "connected_devices": {
    "System_WeatherProvider": {
      "category": [
        "WeatherProvider"
      ],
      "tags": [
        "WeatherProvider"
      ]
    },
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Kitchen_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Kitchen",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "read",
        "var": "Weather",
        "src": "WeatherProvider.Weather"
      },
      {
        "op": "call",
        "target": "Speaker.Speak",
        "args": {
          "Text": "Today's weather is $Weather"
        },
        "var": "Weather"
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "Weather = (#WeatherProvider).weatherProvider_weather\n(#Speaker).speaker_speak(\"Today's weather is \" + Weather)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"Weather = (#WeatherProvider).weatherProvider_weather\n(#Speaker).speaker_speak(\\\"Today's weather is \\\" + Weather)\"\n}"
}