{
  "command_eng": "If it is raining, set all dehumidifiers in the house to drying mode.",
  "connected_devices": {
    "Outdoor_Rain": {
      "category": [
        "RainSensor"
      ],
      "tags": [
        "Outdoor",
        "RainSensor"
      ]
    },
    "Indoor_Rain": {
      "category": [
        "RainSensor"
      ],
      "tags": [
        "Indoor",
        "RainSensor"
      ]
    },
    "House_Dehum_1": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "House",
        "Dehumidifier"
      ]
    },
    "House_Dehum_2": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "House",
        "Dehumidifier"
      ]
    },
    "Garage_Dehum": {
      "category": [
        "Dehumidifier"
      ],
      "tags": [
        "Garage",
        "Dehumidifier"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "RainSensor.Rain == true",
        "then": [
          {
            "op": "call",
            "target": "Dehumidifier.SetDehumidifierMode",
            "args": {
              "Mode": "drying"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#RainSensor).rainSensor_rain == true) {\nall(#Dehumidifier #House).dehumidifier_setDehumidifierMode(\"drying\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#RainSensor).rainSensor_rain == true) {\nall(#Dehumidifier #House).dehumidifier_setDehumidifierMode(\\\"drying\\\")\\n}\"\n}"
}