{
  "command_eng": "When any light in the hallway is turned on, turn off all lights in the living room after 5 minutes.",
  "connected_devices": {
    "Hallway_Light_1": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Hallway",
        "Light",
        "Switch"
      ]
    },
    "Hallway_Light_2": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Hallway",
        "Light",
        "Switch"
      ]
    },
    "LivingRoom_Light_1": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "Light",
        "Switch"
      ]
    },
    "LivingRoom_Light_2": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "Light",
        "Switch"
      ]
    },
    "Kitchen_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Kitchen",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "100 MSEC",
        "body": [
          {
            "op": "wait",
            "cond": "Light.Hallway == true",
            "edge": "rising"
          },
          {
            "op": "delay",
            "duration": "5 MIN"
          },
          {
            "op": "call",
            "target": "Light.MoveToBrightness",
            "args": {
              "Brightness": 0.0,
              "Rate": 0.0
            }
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 100,
    "script": "triggered := false\nif ((#Light #LivingRoom).hallway == true) {\nif (triggered == false) {\ndelay(5 MIN)\n(#Light #LivingRoom).light_moveToBrightness(0.0, 0.0)\n        triggered = true\n}\n}\nelse {\ntriggered = false\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 100,\n  \"script\": \"triggered := false\nif ((#Light #LivingRoom).hallway == true) {\nif (triggered == false) {\ndelay(5 MIN)\n(#Light #LivingRoom).light_moveToBrightness(0.0, 0.0)\n        triggered = true\n}\n}\nelse {\ntriggered = false\n}\"\n}"
}