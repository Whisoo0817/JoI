{
  "command_eng": "If the cloud service is activated, upload test.png file to the cloud.",
  "connected_devices": {
    "Main_CloudServiceProvider": {
      "category": [
        "CloudServiceProvider"
      ],
      "tags": [
        "CloudServiceProvider",
        "Main"
      ]
    },
    "Backup_CloudServiceProvider": {
      "category": [
        "CloudServiceProvider"
      ],
      "tags": [
        "CloudServiceProvider",
        "Backup"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "CloudServiceProvider.IsAvailable == true",
        "then": [
          {
            "op": "call",
            "target": "CloudServiceProvider.UploadFile",
            "args": {
              "File": "test.png"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#CloudServiceProvider).cloudServiceProvider_isAvailable == true) {\n(#CloudServiceProvider).cloudServiceProvider_uploadFile(\"test.png\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#CloudServiceProvider).cloudServiceProvider_isAvailable == true) {\n(#CloudServiceProvider).cloudServiceProvider_uploadFile(\\\"test.png\\\")\\n}\"\n}"
}