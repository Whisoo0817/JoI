{
  "command_eng": "If the sound sensor level in livingroom is over 50, stop the speaker.",
  "connected_devices": {
    "LivingRoom_SoundSensor": {
      "category": [
        "SoundSensor"
      ],
      "tags": [
        "LivingRoom",
        "SoundSensor"
      ]
    },
    "Kitchen_SoundSensor": {
      "category": [
        "SoundSensor"
      ],
      "tags": [
        "Kitchen",
        "SoundSensor"
      ]
    },
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "SoundSensor.Sound > 50",
        "then": [
          {
            "op": "call",
            "target": "Speaker.Stop",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#SoundSensor #LivingRoom).soundSensor_sound > 50) {\n(#Speaker).speaker_stop()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#SoundSensor #LivingRoom).soundSensor_sound > 50) {\n(#Speaker).speaker_stop()\n}\"\n}"
}