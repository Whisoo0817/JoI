{
  "command_eng": "Set the oven mode to Bake and change it to warming mode after 10 minutes.",
  "connected_devices": {
    "Kitchen_Oven": {
      "category": [
        "Oven"
      ],
      "tags": [
        "Kitchen",
        "Oven"
      ]
    },
    "Basement_Oven": {
      "category": [
        "Oven"
      ],
      "tags": [
        "Basement",
        "Oven"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "call",
        "target": "Oven.SetOvenMode",
        "args": {
          "Mode": "Bake"
        }
      },
      {
        "op": "delay",
        "duration": "10 MIN"
      },
      {
        "op": "call",
        "target": "Oven.SetOvenMode",
        "args": {
          "Mode": "Bake"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "(#Oven).oven_setOvenMode(\"Bake\")\ndelay(10 MIN)\n(#Oven).oven_setOvenMode(\"Bake\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"(#Oven).oven_setOvenMode(\\\"Bake\\\")\\ndelay(10 MIN)\\n(#Oven).oven_setOvenMode(\\\"Bake\\\")\"\n}"
}