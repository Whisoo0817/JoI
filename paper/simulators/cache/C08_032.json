{
  "command_eng": "Each time the door is opened, turn on all lights in the hallway and living room.",
  "connected_devices": {
    "Door_1": {
      "category": [
        "Door"
      ],
      "tags": [
        "Door"
      ]
    },
    "Door_2": {
      "category": [
        "Door"
      ],
      "tags": [
        "Door"
      ]
    },
    "Hall_Light_1": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Hallway",
        "Light",
        "Switch"
      ]
    },
    "Hall_Light_2": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Hallway",
        "Light",
        "Switch"
      ]
    },
    "LR_Light_1": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "Light",
        "Switch"
      ]
    },
    "LR_Light_2": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "Light",
        "Switch"
      ]
    },
    "Kitchen_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Kitchen",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "cycle",
        "until": null,
        "period": "100 MSEC",
        "body": [
          {
            "op": "wait",
            "cond": "Door.DoorState == \"open\"",
            "edge": "rising"
          },
          {
            "op": "call",
            "target": "Light.MoveToBrightness",
            "args": {
              "Brightness": 100.0,
              "Rate": 0.0
            }
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 100,
    "script": "triggered := false\nif ((#Door).door_doorState == \"open\") {\nif (triggered == false) {\nall(#Light #Hallway).light_moveToBrightness(100, 0)\nall(#Light #LivingRoom).light_moveToBrightness(100, 0)\n        triggered = true\n}\n}\nelse {\ntriggered = false\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 100,\n  \"script\": \"triggered := false\nif ((#Door).door_doorState == \\\"open\\\") {\\nif (triggered == false) {\\nall(#Light #Hallway).light_moveToBrightness(100, 0)\\nall(#Light #LivingRoom).light_moveToBrightness(100, 0)\\n        triggered = true\\n}\\n}\\nelse {\\ntriggered = false\\n}\"\n}"
}