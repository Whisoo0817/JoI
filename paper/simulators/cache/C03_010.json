{
  "command_eng": "If the charger is fully charged, turn off the charger.",
  "connected_devices": {
    "Main_Charger": {
      "category": [
        "Charger",
        "Switch"
      ],
      "tags": [
        "Main",
        "Charger"
      ]
    },
    "Garage_Charger": {
      "category": [
        "Charger",
        "Switch"
      ],
      "tags": [
        "Garage",
        "Charger"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "Charger.ChargingState == \"fullyCharged\"",
        "then": [
          {
            "op": "call",
            "target": "Switch.Off",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Charger).charger_chargingState == \"fullyCharged\") {\n(#Charger #Switch).switch_off()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Charger).charger_chargingState == \\\"fullyCharged\\\") {\\n(#Charger #Switch).switch_off()\\n}\"\n}"
}