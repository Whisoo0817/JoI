{
  "command_eng": "Every day at midnight, capture an image with all cameras in the parking lot.",
  "connected_devices": {
    "P_Cam_1": {
      "category": [
        "Camera"
      ],
      "tags": [
        "ParkingLot",
        "Camera"
      ]
    },
    "P_Cam_2": {
      "category": [
        "Camera"
      ],
      "tags": [
        "ParkingLot",
        "Camera"
      ]
    },
    "Entrance_Cam": {
      "category": [
        "Camera"
      ],
      "tags": [
        "Entrance",
        "Camera"
      ]
    },
    "Garage_Cam": {
      "category": [
        "Camera"
      ],
      "tags": [
        "Garage",
        "Camera"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 0 * * *"
      },
      {
        "op": "call",
        "target": "Camera.CaptureImage",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 0 * * *",
    "period": 0,
    "script": "all(#Camera #ParkingLot).camera_captureImage()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 0 * * *\",\n  \"period\": 0,\n  \"script\": \"all(#Camera #ParkingLot).camera_captureImage()\"\n}"
}