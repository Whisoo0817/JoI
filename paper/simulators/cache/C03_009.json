{
  "command_eng": "If the laundry dryer is in low noise mode, switch it to quick mode.",
  "connected_devices": {
    "Main_LaundryDryer": {
      "category": [
        "LaundryDryer"
      ],
      "tags": [
        "Main",
        "LaundryDryer"
      ]
    },
    "Garage_LaundryDryer": {
      "category": [
        "LaundryDryer"
      ],
      "tags": [
        "Garage",
        "LaundryDryer"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "read",
        "var": "currentMode",
        "src": "LaundryDryer.LaundryDryerMode"
      },
      {
        "op": "if",
        "cond": "LaundryDryer.LaundryDryerMode == \"lownoise\"",
        "then": [
          {
            "op": "call",
            "target": "LaundryDryer.SetLaundryDryerMode",
            "args": {
              "Mode": "quick"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "currentMode = (#LaundryDryer).laundryDryer_laundryDryerMode\nif ((#LaundryDryer).laundryDryer_laundryDryerMode == \"lownoise\") {\n(#LaundryDryer).laundryDryer_setLaundryDryerMode(\"quick\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"currentMode = (#LaundryDryer).laundryDryer_laundryDryerMode\nif ((#LaundryDryer).laundryDryer_laundryDryerMode == \\\"lownoise\\\") {\\n(#LaundryDryer).laundryDryer_setLaundryDryerMode(\\\"quick\\\")\\n}\"\n}"
}