{
  "command_eng": "Turn on the light every morning at 8 AM.",
  "connected_devices": {
    "Main_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Main",
        "Light",
        "Switch"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 8 * * *"
      },
      {
        "op": "call",
        "target": "Light.MoveToBrightness",
        "args": {
          "Brightness": 100.0,
          "Rate": 0.0
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 8 * * *",
    "period": 0,
    "script": "(#Light).light_moveToBrightness(100.0, 0.0)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 8 * * *\",\n  \"period\": 0,\n  \"script\": \"(#Light).light_moveToBrightness(100.0, 0.0)\"\n}"
}