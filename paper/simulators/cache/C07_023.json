{
  "command_eng": "When the office button is pushed, turn on all humidifiers in office.",
  "connected_devices": {
    "Office_Button": {
      "category": [
        "Button"
      ],
      "tags": [
        "Office",
        "Button"
      ]
    },
    "Lobby_Button": {
      "category": [
        "Button"
      ],
      "tags": [
        "Lobby",
        "Button"
      ]
    },
    "Office_Humidifier_1": {
      "category": [
        "Humidifier",
        "Switch"
      ],
      "tags": [
        "Office",
        "Humidifier",
        "Switch"
      ]
    },
    "Office_Humidifier_2": {
      "category": [
        "Humidifier",
        "Switch"
      ],
      "tags": [
        "Office",
        "Humidifier",
        "Switch"
      ]
    },
    "Bedroom_Humidifier": {
      "category": [
        "Humidifier",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "Humidifier",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "Button.Button == \"pushed\"",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Switch.On",
        "args": {
          "all": [
            "Office",
            "Switch"
          ]
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#Office #Button).button_button == \"pushed\")\nall(#Office #Humidifier).switch_on()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#Office #Button).button_button == \\\"pushed\\\")\\nall(#Office #Humidifier).switch_on()\"\n}"
}