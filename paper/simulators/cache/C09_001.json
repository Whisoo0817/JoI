  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"(#Television).television_setChannel(7)\ndelay(1 HOUR)\n(#Television).television_setChannel(11)\"\n}"
