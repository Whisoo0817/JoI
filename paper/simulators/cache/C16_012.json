{
  "command_eng": "At 6 PM, if any window is open, close all of them.",
  "connected_devices": {
    "LivingRoom_Window": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "LivingRoom",
        "Window",
        "WindowCovering"
      ]
    },
    "Bedroom_Window": {
      "category": [
        "WindowCovering"
      ],
      "tags": [
        "Bedroom",
        "Window",
        "WindowCovering"
      ]
    },
    "Entrance_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Entrance",
        "Door"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 18 * * *"
      },
      {
        "op": "if",
        "cond": "WindowCovering.CurrentPosition > 0",
        "then": [
          {
            "op": "call",
            "target": "WindowCovering.DownOrClose",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 18 * * *",
    "period": 0,
    "script": "if (all(#WindowCovering #Window).windowCovering_currentPosition >| 0) {\nall(#WindowCovering #Window).windowCovering_downOrClose()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 18 * * *\",\n  \"period\": 0,\n  \"script\": \"if (all(#WindowCovering #Window).windowCovering_currentPosition >| 0) {\nall(#WindowCovering #Window).windowCovering_downOrClose()\n}\"\n}"
}