{
  "command_eng": "If any presence sensor on floor 1 detects presence, turn on all lights on floor 1.",
  "connected_devices": {
    "F1_Pres_1": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Floor1",
        "PresenceSensor"
      ]
    },
    "F1_Pres_2": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Floor1",
        "PresenceSensor"
      ]
    },
    "F2_Pres": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Floor2",
        "PresenceSensor"
      ]
    },
    "F3_Pres": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Floor3",
        "PresenceSensor"
      ]
    },
    "F1_Light_1": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Floor1",
        "Light",
        "Switch"
      ]
    },
    "F1_Light_2": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Floor1",
        "Light",
        "Switch"
      ]
    },
    "F2_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Floor2",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "PresenceSensor.Presence == true",
        "then": [
          {
            "op": "call",
            "target": "Light.MoveToBrightness",
            "args": {
              "Brightness": 100.0,
              "Rate": 0.0
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if (all(#PresenceSensor #Floor1).presenceSensor_presence ==| true) {\nall(#Light #Floor1).light_moveToBrightness(100.0, 0.0)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if (all(#PresenceSensor #Floor1).presenceSensor_presence ==| true) {\nall(#Light #Floor1).light_moveToBrightness(100.0, 0.0)\n}\"\n}"
}