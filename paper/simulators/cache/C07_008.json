{
  "command_eng": "When the temperature reaches 35 degrees or higher, set the air conditioner to 30 degrees.",
  "connected_devices": {
    "LivingRoom_TempSensor": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "LivingRoom",
        "TemperatureSensor"
      ]
    },
    "Bedroom_TempSensor": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Bedroom",
        "TemperatureSensor"
      ]
    },
    "LivingRoom_AC": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "AirConditioner"
      ]
    },
    "Bedroom_AC": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "AirConditioner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "TemperatureSensor.Temperature >= 35",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "AirConditioner.SetTargetTemperature",
        "args": {
          "Temperature": 30.0
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#TemperatureSensor).temperatureSensor_temperature >= 35)\n(#AirConditioner).airConditioner_setTargetTemperature(30.0)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#TemperatureSensor).temperatureSensor_temperature >= 35)\n(#AirConditioner).airConditioner_setTargetTemperature(30.0)\"\n}"
}