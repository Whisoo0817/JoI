{
  "command_eng": "If the baby room sound is 50dB or higher and the living room speaker is stopped, say the baby is awake through the speaker and play \"lullaby.mp3\" file.",
  "connected_devices": {
    "BabyRoom_Sound": {
      "category": [
        "SoundSensor"
      ],
      "tags": [
        "BabyRoom",
        "SoundSensor"
      ]
    },
    "Bedroom_Sound": {
      "category": [
        "SoundSensor"
      ],
      "tags": [
        "Bedroom",
        "SoundSensor"
      ]
    },
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "SoundSensor.Sound >= 50 and Speaker.PlaybackState == \"stopped\"",
        "then": [
          {
            "op": "call",
            "target": "Speaker.Speak",
            "args": {
              "Text": "the baby is awake"
            }
          },
          {
            "op": "call",
            "target": "Speaker.Play",
            "args": {
              "MediaSource": "lullaby.mp3"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#SoundSensor #BabyRoom).soundSensor_sound >= 50 and (#Speaker #LivingRoom).speaker_playbackState == \"stopped\") {\n(#Speaker #LivingRoom).speaker_speak(\"the baby is awake\")\n(#Speaker #LivingRoom).speaker_play(\"lullaby.mp3\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#SoundSensor #BabyRoom).soundSensor_sound >= 50 and (#Speaker #LivingRoom).speaker_playbackState == \\\"stopped\\\") {\\n(#Speaker #LivingRoom).speaker_speak(\\\"the baby is awake\\\")\\n(#Speaker #LivingRoom).speaker_play(\\\"lullaby.mp3\\\")\\n}\"\n}"
}