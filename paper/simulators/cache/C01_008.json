{
  "command_eng": "Announce the indoor temperature through the speaker.",
  "connected_devices": {
    "LivingRoom_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "LivingRoom",
        "TemperatureSensor"
      ]
    },
    "Bedroom_Temp": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Bedroom",
        "TemperatureSensor"
      ]
    },
    "LivingRoom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "LivingRoom",
        "Speaker"
      ]
    },
    "Kitchen_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Kitchen",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "read",
        "var": "temp",
        "src": "TemperatureSensor.Temperature"
      },
      {
        "op": "call",
        "target": "Speaker.Speak",
        "args": {
          "Text": "The indoor temperature is $temp"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "temp = (#TemperatureSensor).temperatureSensor_temperature\n(#Speaker).speaker_speak(\"The indoor temperature is \" + temp)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"temp = (#TemperatureSensor).temperatureSensor_temperature\n(#Speaker).speaker_speak(\\\"The indoor temperature is \\\" + temp)\"\n}"
}