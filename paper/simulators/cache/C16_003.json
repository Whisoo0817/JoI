{
  "command_eng": "Every 30 minutes from 7 PM to 10 PM, check the robot vacuum cleaner and start it in auto mode if it is stopped.",
  "connected_devices": {
    "Living_RVC": {
      "category": [
        "RobotVacuumCleaner"
      ],
      "tags": [
        "Living",
        "RobotVacuumCleaner"
      ]
    },
    "Bedroom_RVC": {
      "category": [
        "RobotVacuumCleaner"
      ],
      "tags": [
        "Bedroom",
        "RobotVacuumCleaner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 19 * * *"
      },
      {
        "op": "cycle",
        "until": "clock.time >= 2200",
        "period": "30 MIN",
        "body": [
          {
            "op": "if",
            "cond": "RobotVacuumCleaner.RobotVacuumCleanerRunMode == \"stopped\"",
            "then": [
              {
                "op": "call",
                "target": "RobotVacuumCleaner.SetRobotVacuumCleanerCleaningMode",
                "args": {
                  "Mode": "auto"
                }
              }
            ],
            "else": []
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 19 * * *",
    "period": 1800000,
    "script": "if (clock.time >= 2200) {\nbreak\n}\nif ((#RobotVacuumCleaner).robotVacuumCleaner_robotVacuumCleanerRunMode == \"stopped\") {\n(#RobotVacuumCleaner).robotVacuumCleaner_setRobotVacuumCleanerCleaningMode(\"auto\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 19 * * *\",\n  \"period\": 1800000,\n  \"script\": \"if (clock.time >= 2200) {\nbreak\n}\nif ((#RobotVacuumCleaner).robotVacuumCleaner_robotVacuumCleanerRunMode == \\\"stopped\\\") {\\n(#RobotVacuumCleaner).robotVacuumCleaner_setRobotVacuumCleanerCleaningMode(\\\"auto\\\")\\n}\"\n}"
}