{
  "command_eng": "If the outdoor very fine dust level is 15 or higher, sound the emergency siren.",
  "connected_devices": {
    "Main_WeatherProvider": {
      "category": [
        "WeatherProvider"
      ],
      "tags": [
        "WeatherProvider",
        "Main"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "Siren",
        "Main"
      ]
    },
    "Garage_Siren": {
      "category": [
        "Siren",
        "Switch"
      ],
      "tags": [
        "Siren",
        "Garage"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "WeatherProvider.Pm25Weather >= 15",
        "then": [
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "emergency"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#WeatherProvider #Main).weatherProvider_pm25Weather >= 15) {\n(#Siren).siren_setSirenMode(\"emergency\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#WeatherProvider #Main).weatherProvider_pm25Weather >= 15) {\n(#Siren).siren_setSirenMode(\\\"emergency\\\")\\n}\"\n}"
}