{
  "command_eng": "If the weather is rainy and no one is being detected, lock the door and close the valve.",
  "connected_devices": {
    "Main_Weather": {
      "category": [
        "WeatherProvider"
      ],
      "tags": [
        "Main",
        "WeatherProvider"
      ]
    },
    "Outdoor_Weather": {
      "category": [
        "WeatherProvider"
      ],
      "tags": [
        "Outdoor",
        "WeatherProvider"
      ]
    },
    "Living_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Living",
        "PresenceSensor"
      ]
    },
    "Bedroom_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Bedroom",
        "PresenceSensor"
      ]
    },
    "Entrance_Lock": {
      "category": [
        "DoorLock"
      ],
      "tags": [
        "Entrance",
        "DoorLock"
      ]
    },
    "Garage_Lock": {
      "category": [
        "DoorLock"
      ],
      "tags": [
        "Garage",
        "DoorLock"
      ]
    },
    "Main_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Main",
        "Valve"
      ]
    },
    "Garden_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Garden",
        "Valve"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "WeatherProvider.Weather == \"rain\" and PresenceSensor.Presence == false",
        "then": [
          {
            "op": "call",
            "target": "DoorLock.Lock",
            "args": {}
          },
          {
            "op": "call",
            "target": "Valve.Close",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#WeatherProvider).weatherProvider_weather == \"rain\" and (#PresenceSensor).presenceSensor_presence == false) {\n(#DoorLock).doorLock_lock()\n(#Valve).valve_close()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#WeatherProvider).weatherProvider_weather == \\\"rain\\\" and (#PresenceSensor).presenceSensor_presence == false) {\\n(#DoorLock).doorLock_lock()\\n(#Valve).valve_close()\\n}\"\n}"
}