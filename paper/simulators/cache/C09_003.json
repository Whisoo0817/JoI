{
  "command_eng": "Set the air purifier to auto mode and switch to sleep mode after 2 hours.",
  "connected_devices": {
    "LivingRoom_AirPurifier": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "LivingRoom",
        "AirPurifier"
      ]
    },
    "Bedroom_AirPurifier": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Bedroom",
        "AirPurifier"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "call",
        "target": "AirPurifier.SetAirPurifierMode",
        "args": {
          "Mode": "auto"
        }
      },
      {
        "op": "delay",
        "duration": "2 HOUR"
      },
      {
        "op": "call",
        "target": "AirPurifier.SetAirPurifierMode",
        "args": {
          "Mode": "auto"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "(#AirPurifier).airPurifier_setAirPurifierMode(\"auto\")\ndelay(2 HOUR)\n(#AirPurifier).airPurifier_setAirPurifierMode(\"sleep\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"(#AirPurifier).airPurifier_setAirPurifierMode(\\\"auto\\\")\\ndelay(2 HOUR)\\n(#AirPurifier).airPurifier_setAirPurifierMode(\\\"sleep\\\")\"\n}"
}