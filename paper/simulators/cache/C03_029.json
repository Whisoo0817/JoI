{
  "command_eng": "If the face recognized at the entrance is 'visitor', start streaming from the entrance camera.",
  "connected_devices": {
    "Entrance_Face": {
      "category": [
        "FaceRecognizer"
      ],
      "tags": [
        "Entrance",
        "FaceRecognizer"
      ]
    },
    "Garage_Face": {
      "category": [
        "FaceRecognizer"
      ],
      "tags": [
        "Garage",
        "FaceRecognizer"
      ]
    },
    "Lobby_Face": {
      "category": [
        "FaceRecognizer"
      ],
      "tags": [
        "Lobby",
        "FaceRecognizer"
      ]
    },
    "Entrance_Cam": {
      "category": [
        "Camera"
      ],
      "tags": [
        "Entrance",
        "Camera"
      ]
    },
    "Garage_Cam": {
      "category": [
        "Camera"
      ],
      "tags": [
        "Garage",
        "Camera"
      ]
    },
    "Lobby_Cam": {
      "category": [
        "Camera"
      ],
      "tags": [
        "Lobby",
        "Camera"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "FaceRecognizer.RecognizedResult == 'visitor'",
        "then": [
          {
            "op": "call",
            "target": "Camera.StartStream",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#FaceRecognizer #Entrance).faceRecognizer_recognizedResult == \"visitor\") {\n(#Camera #Entrance).camera_startStream()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#FaceRecognizer #Entrance).faceRecognizer_recognizedResult == \\\"visitor\\\") {\\n(#Camera #Entrance).camera_startStream()\\n}\"\n}"
}