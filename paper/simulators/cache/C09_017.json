{
  "command_eng": "Turn off the bathroom light and turn on after 5 minutes.",
  "connected_devices": {
    "Bathroom_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Bathroom",
        "Light",
        "Switch"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "call",
        "target": "Light.MoveToBrightness",
        "args": {
          "Brightness": 0.0,
          "Rate": 0.0
        }
      },
      {
        "op": "delay",
        "duration": "5 MIN"
      },
      {
        "op": "call",
        "target": "Light.MoveToBrightness",
        "args": {
          "Brightness": 100.0,
          "Rate": 0.0
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "(#Light #Bathroom).light_moveToBrightness(0.0, 0.0)\ndelay(5 MIN)\n(#Light #Bathroom).light_moveToBrightness(100.0, 0.0)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"(#Light #Bathroom).light_moveToBrightness(0.0, 0.0)\ndelay(5 MIN)\n(#Light #Bathroom).light_moveToBrightness(100.0, 0.0)\"\n}"
}