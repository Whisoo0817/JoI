{
  "command_eng": "If smoke is detected in the kitchen, sound the kitchen siren in fire mode.",
  "connected_devices": {
    "Kitchen_Smoke": {
      "category": [
        "SmokeDetector"
      ],
      "tags": [
        "Kitchen",
        "SmokeDetector"
      ]
    },
    "Bedroom_Smoke": {
      "category": [
        "SmokeDetector"
      ],
      "tags": [
        "Bedroom",
        "SmokeDetector"
      ]
    },
    "LR_Smoke": {
      "category": [
        "SmokeDetector"
      ],
      "tags": [
        "LivingRoom",
        "SmokeDetector"
      ]
    },
    "Kitchen_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Kitchen",
        "Siren"
      ]
    },
    "Bedroom_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Bedroom",
        "Siren"
      ]
    },
    "Main_Siren": {
      "category": [
        "Siren"
      ],
      "tags": [
        "Main",
        "Siren"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "SmokeDetector.Smoke == true",
        "then": [
          {
            "op": "call",
            "target": "Siren.SetSirenMode",
            "args": {
              "Mode": "fire"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#Kitchen #SmokeDetector).smokeDetector_smoke == true) {\n(#Kitchen #Siren).siren_setSirenMode(\"fire\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#Kitchen #SmokeDetector).smokeDetector_smoke == true) {\n(#Kitchen #Siren).siren_setSirenMode(\\\"fire\\\")\\n}\"\n}"
}