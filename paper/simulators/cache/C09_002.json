{
  "command_eng": "Set the air conditioner to cool mode and switch to auto mode after 30 minutes.",
  "connected_devices": {
    "LivingRoom_AirConditioner": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "AirConditioner"
      ]
    },
    "Bedroom_AirConditioner": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "AirConditioner"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "call",
        "target": "AirConditioner.SetAirConditionerMode",
        "args": {
          "Mode": "cool"
        }
      },
      {
        "op": "delay",
        "duration": "30 MIN"
      },
      {
        "op": "call",
        "target": "AirConditioner.SetAirConditionerMode",
        "args": {
          "Mode": "cool"
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "(#AirConditioner).airConditioner_setAirConditionerMode(\"cool\")\ndelay(30 MIN)\n(#AirConditioner).airConditioner_setAirConditionerMode(\"cool\")"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"(#AirConditioner).airConditioner_setAirConditionerMode(\\\"cool\\\")\\ndelay(30 MIN)\\n(#AirConditioner).airConditioner_setAirConditionerMode(\\\"cool\\\")\"\n}"
}