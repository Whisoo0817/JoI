{
  "command_eng": "If the temperature is 28 degrees or higher and the humidity is 70% or higher, set the air conditioner to cool mode and 24 degrees.",
  "connected_devices": {
    "LivingRoom_TemperatureSensor": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "LivingRoom",
        "TemperatureSensor"
      ]
    },
    "Bedroom_TemperatureSensor": {
      "category": [
        "TemperatureSensor"
      ],
      "tags": [
        "Bedroom",
        "TemperatureSensor"
      ]
    },
    "LivingRoom_HumiditySensor": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "LivingRoom",
        "HumiditySensor"
      ]
    },
    "Bedroom_HumiditySensor": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Bedroom",
        "HumiditySensor"
      ]
    },
    "LivingRoom_AirConditioner": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "AirConditioner",
        "Switch"
      ]
    },
    "Bedroom_AirConditioner": {
      "category": [
        "AirConditioner",
        "Switch"
      ],
      "tags": [
        "Bedroom",
        "AirConditioner",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "TemperatureSensor.Temperature >= 28 and HumiditySensor.Humidity >= 70",
        "then": [
          {
            "op": "call",
            "target": "AirConditioner.SetAirConditionerMode",
            "args": {
              "Mode": "cool"
            }
          },
          {
            "op": "call",
            "target": "AirConditioner.SetTargetTemperature",
            "args": {
              "Temperature": 24.0
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#TemperatureSensor).temperatureSensor_temperature >= 28 and (#HumiditySensor).humiditySensor_humidity >= 70) {\n(#AirConditioner).airConditioner_setAirConditionerMode(\"cool\")\n(#AirConditioner).airConditioner_setTargetTemperature(24.0)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#TemperatureSensor).temperatureSensor_temperature >= 28 and (#HumiditySensor).humiditySensor_humidity >= 70) {\n(#AirConditioner).airConditioner_setAirConditionerMode(\\\"cool\\\")\\n(#AirConditioner).airConditioner_setTargetTemperature(24.0)\\n}\"\n}"
}