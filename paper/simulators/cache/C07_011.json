{
  "command_eng": "When the humidity exceeds 80%, start the dehumidifier in drying mode.",
  "connected_devices": {
    "LivingRoom_HumiditySensor": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "LivingRoom",
        "HumiditySensor"
      ]
    },
    "Bedroom_HumiditySensor": {
      "category": [
        "HumiditySensor"
      ],
      "tags": [
        "Bedroom",
        "HumiditySensor"
      ]
    },
    "LivingRoom_Dehumidifier": {
      "category": [
        "Dehumidifier",
        "Switch"
      ],
      "tags": [
        "LivingRoom",
        "Dehumidifier"
      ]
    },
    "Bathroom_Dehumidifier": {
      "category": [
        "Dehumidifier",
        "Switch"
      ],
      "tags": [
        "Bathroom",
        "Dehumidifier"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "HumiditySensor.Humidity > 80",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Switch.On",
        "args": {}
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#HumiditySensor).humiditySensor_humidity > 80)\n(#Dehumidifier).switch_on()"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#HumiditySensor).humiditySensor_humidity > 80)\n(#Dehumidifier).switch_on()\"\n}"
}