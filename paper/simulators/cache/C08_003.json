{
  "command_eng": "When button 3 of the multi-button is pressed, set all living room lights to 30% brightness.",
  "connected_devices": {
    "LR_MB": {
      "category": [
        "MultiButton"
      ],
      "tags": [
        "LivingRoom",
        "MultiButton"
      ]
    },
    "Bedroom_MB": {
      "category": [
        "MultiButton"
      ],
      "tags": [
        "Bedroom",
        "MultiButton"
      ]
    },
    "LR_Light_1": {
      "category": [
        "Light"
      ],
      "tags": [
        "LivingRoom",
        "Light"
      ]
    },
    "LR_Light_2": {
      "category": [
        "Light"
      ],
      "tags": [
        "LivingRoom",
        "Light"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light"
      ],
      "tags": [
        "Bedroom",
        "Light"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "MultiButton.Button3 == \"pushed\"",
        "edge": "none"
      },
      {
        "op": "call",
        "target": "Light.MoveToBrightness",
        "args": {
          "Brightness": 30.0,
          "Rate": 0.0
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#MultiButton).multiButton_button3 == \"pushed\")\nall(#Light #LivingRoom).light_moveToBrightness(30.0, 0.0)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#MultiButton).multiButton_button3 == \\\"pushed\\\")\\nall(#Light #LivingRoom).light_moveToBrightness(30.0, 0.0)\"\n}"
}