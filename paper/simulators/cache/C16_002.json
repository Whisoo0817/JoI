{
  "command_eng": "Every Monday at 8 AM, if both the safe and the door lock are locked, say 'It is safe' through the speaker",
  "connected_devices": {
    "Main_Safe": {
      "category": [
        "Safe"
      ],
      "tags": [
        "Main",
        "Safe"
      ]
    },
    "Bedroom_Safe": {
      "category": [
        "Safe"
      ],
      "tags": [
        "Bedroom",
        "Safe"
      ]
    },
    "Entrance_Lock": {
      "category": [
        "DoorLock"
      ],
      "tags": [
        "Entrance",
        "DoorLock"
      ]
    },
    "Garage_Lock": {
      "category": [
        "DoorLock"
      ],
      "tags": [
        "Garage",
        "DoorLock"
      ]
    },
    "Living_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Living",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 8 * * 1"
      },
      {
        "op": "if",
        "cond": "Safe.SafeState == \"closed\" and DoorLock.DoorLockState == \"closed\"",
        "then": [
          {
            "op": "call",
            "target": "Speaker.Speak",
            "args": {
              "Text": "It is safe"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 8 * * 1",
    "period": 0,
    "script": "if ((#Safe).safe_safeState == \"closed\" and (#DoorLock).doorLock_doorLockState == \"closed\") {\n(#Speaker).speaker_speak(\"It is safe\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 8 * * 1\",\n  \"period\": 0,\n  \"script\": \"if ((#Safe).safe_safeState == \\\"closed\\\" and (#DoorLock).doorLock_doorLockState == \\\"closed\\\") {\\n(#Speaker).speaker_speak(\\\"It is safe\\\")\\n}\"\n}"
}