{
  "command_eng": "If the dust level concentration is 2000ppm or above, close the door and close the valve after 4 hours.",
  "connected_devices": {
    "Home_WeatherProvider": {
      "category": [
        "WeatherProvider"
      ],
      "tags": [
        "WeatherProvider"
      ]
    },
    "Front_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Front",
        "Door"
      ]
    },
    "Back_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Back",
        "Door"
      ]
    },
    "Kitchen_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Kitchen",
        "Valve"
      ]
    },
    "Basement_Valve": {
      "category": [
        "Valve"
      ],
      "tags": [
        "Basement",
        "Valve"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "WeatherProvider.Pm25Weather >= 2000",
        "then": [
          {
            "op": "delay",
            "duration": "4 HOUR"
          },
          {
            "op": "call",
            "target": "Door.Close",
            "args": {}
          },
          {
            "op": "call",
            "target": "Valve.Close",
            "args": {}
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#WeatherProvider).weatherProvider_pm25Weather >= 2000) {\ndelay(4 HOUR)\n(#Door).door_close()\n(#Valve).valve_close()\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#WeatherProvider).weatherProvider_pm25Weather >= 2000) {\ndelay(4 HOUR)\n(#Door).door_close()\n(#Valve).valve_close()\n}\"\n}"
}