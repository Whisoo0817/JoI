{
  "command_eng": "Every hour from midnight to 5 AM, if at least one door is open, turn all hallway lights to 50%.",
  "connected_devices": {
    "Front_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Front",
        "Door"
      ]
    },
    "Hallway_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Hallway",
        "Door"
      ]
    },
    "Hallway_Light_1": {
      "category": [
        "Light",
        "Switch",
        "LevelControl"
      ],
      "tags": [
        "Hallway",
        "Light",
        "Switch"
      ]
    },
    "Hallway_Light_2": {
      "category": [
        "Light",
        "Switch",
        "LevelControl"
      ],
      "tags": [
        "Hallway",
        "Light",
        "Switch"
      ]
    },
    "Basement_Door": {
      "category": [
        "Door"
      ],
      "tags": [
        "Basement",
        "Door"
      ]
    },
    "Basement_Light": {
      "category": [
        "Light",
        "Switch",
        "LevelControl"
      ],
      "tags": [
        "Basement",
        "Light",
        "Switch"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "cron",
        "cron": "0 0 * * *"
      },
      {
        "op": "cycle",
        "until": "clock.time >= 0500",
        "period": "1 HOUR",
        "body": [
          {
            "op": "if",
            "cond": "Door.DoorState == \"open\" or Door.DoorState == \"open\"",
            "then": [
              {
                "op": "call",
                "target": "LevelControl.MoveToLevel",
                "args": {
                  "Level": 50.0,
                  "Rate": 0.0
                }
              }
            ],
            "else": []
          }
        ]
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "0 0 * * *",
    "period": 3600000,
    "script": "if (clock.time >= 0500) {\nbreak\n}\nif (all(#Door).door_doorState ==| \"open\" or all(#Door).door_doorState ==| \"open\") {\nall(#Light #LevelControl #Hallway).levelControl_moveToLevel(50.0, 0.0)\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"0 0 * * *\",\n  \"period\": 3600000,\n  \"script\": \"if (clock.time >= 0500) {\nbreak\n}\nif (all(#Door).door_doorState ==| \\\"open\\\" or all(#Door).door_doorState ==| \\\"open\\\") {\\nall(#Light #LevelControl #Hallway).levelControl_moveToLevel(50.0, 0.0)\\n}\"\n}"
}