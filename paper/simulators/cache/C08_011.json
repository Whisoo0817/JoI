{
  "command_eng": "When button 3 of the multi-button is pressed, turn off all lights after 1 hour.",
  "connected_devices": {
    "Main_MB": {
      "category": [
        "MultiButton"
      ],
      "tags": [
        "LivingRoom",
        "MultiButton"
      ]
    },
    "Hall_MB": {
      "category": [
        "MultiButton"
      ],
      "tags": [
        "Hallway",
        "MultiButton"
      ]
    },
    "LR_Light": {
      "category": [
        "Light"
      ],
      "tags": [
        "LivingRoom",
        "Light"
      ]
    },
    "Hall_Light": {
      "category": [
        "Light"
      ],
      "tags": [
        "Hallway",
        "Light"
      ]
    },
    "Bedroom_Light": {
      "category": [
        "Light"
      ],
      "tags": [
        "Bedroom",
        "Light"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "wait",
        "cond": "MultiButton.Button3 == \"pushed\"",
        "edge": "none"
      },
      {
        "op": "delay",
        "duration": "1 HOUR"
      },
      {
        "op": "call",
        "target": "Light.MoveToBrightness",
        "args": {
          "Brightness": 0.0,
          "Rate": 0.0
        }
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "wait until((#MultiButton).multiButton_button3 == \"pushed\")\ndelay(1 HOUR)\nall(#Light).light_moveToBrightness(0, 0)"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"wait until((#MultiButton).multiButton_button3 == \\\"pushed\\\")\\ndelay(1 HOUR)\\nall(#Light).light_moveToBrightness(0, 0)\"\n}"
}