{
  "command_eng": "If the carbon dioxide concentration is 1200ppm or higher and person is being detected, set the air purifier to high mode and announce a warning using the speaker.",
  "connected_devices": {
    "Living_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Living",
        "AirQualitySensor"
      ]
    },
    "Office_AQ": {
      "category": [
        "AirQualitySensor"
      ],
      "tags": [
        "Office",
        "AirQualitySensor"
      ]
    },
    "Living_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Living",
        "PresenceSensor"
      ]
    },
    "Bedroom_Presence": {
      "category": [
        "PresenceSensor"
      ],
      "tags": [
        "Bedroom",
        "PresenceSensor"
      ]
    },
    "Living_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Living",
        "AirPurifier"
      ]
    },
    "Bedroom_AP": {
      "category": [
        "AirPurifier"
      ],
      "tags": [
        "Bedroom",
        "AirPurifier"
      ]
    },
    "Living_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Living",
        "Speaker"
      ]
    },
    "Bedroom_Speaker": {
      "category": [
        "Speaker"
      ],
      "tags": [
        "Bedroom",
        "Speaker"
      ]
    }
  },
  "ir": {
    "timeline": [
      {
        "op": "start_at",
        "anchor": "now"
      },
      {
        "op": "if",
        "cond": "AirQualitySensor.CarbonDioxide >= 1200 && PresenceSensor.Presence == true",
        "then": [
          {
            "op": "call",
            "target": "AirPurifier.SetAirPurifierMode",
            "args": {
              "Mode": "high"
            }
          },
          {
            "op": "call",
            "target": "Speaker.Speak",
            "args": {
              "Text": "warning"
            }
          }
        ],
        "else": []
      }
    ]
  },
  "joi_block": {
    "name": "Scenario",
    "cron": "",
    "period": 0,
    "script": "if ((#AirQualitySensor).airQualitySensor_carbonDioxide >= 1200 and (#PresenceSensor).presenceSensor_presence == true) {\n(#AirPurifier).airPurifier_setAirPurifierMode(\"high\")\n(#Speaker).speaker_speak(\"warning\")\n}"
  },
  "code": "{\n  \"name\": \"Scenario\",\n  \"cron\": \"\",\n  \"period\": 0,\n  \"script\": \"if ((#AirQualitySensor).airQualitySensor_carbonDioxide >= 1200 and (#PresenceSensor).presenceSensor_presence == true) {\n(#AirPurifier).airPurifier_setAirPurifierMode(\\\"high\\\")\\n(#Speaker).speaker_speak(\\\"warning\\\")\\n}\"\n}"
}