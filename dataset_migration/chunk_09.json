    "connected_devices": "{'Basement_Leak': {'category': 'LeakSensor', 'tags': ['Basement', 'LeakSensor']}, 'Main_Valve': {'category': 'Valve', 'tags': ['Main', 'Valve']}, 'Siren': {'category': 'Siren', 'tags': ['Siren']}}"
  },
  {
