[
  {
    "index": "25",
    "category": "6",
    "command_kor": "서버실 온도가 30도 이상이고 에어컨이 꺼져 있으면, 에어컨을 냉방 모드로 켜고 메인 사이렌을 긴급 모드로 울려줘.",
    "command_eng": "If the server room temperature is 30 degrees or higher and the AC is off, turn it on and sound the main emergency siren.",
    "gt": "{\"name\": \"\", \"cron\": \"\", \"period\": 0, \"script\": \"\\nif ((#ServerRoom #TemperatureSensor).temperatureSensor_temperature >= 30 and (#ServerRoom #AirConditioner).switch_switch == false) {\\n\\n    (#ServerRoom #AirConditioner).airConditioner_setAirConditionerMode(\\\"cool\\\")\\n\\n    (#Main #Siren).siren_setSirenMode(\\\"emergency\\\")\\n\\n}\"}",
    "connected_devices": "{'Server_Temp': {'category': 'TemperatureSensor', 'tags': ['ServerRoom', 'TemperatureSensor']}, 'Server_AC': {'category': ['AirConditioner', 'Switch'], 'tags': ['ServerRoom', 'AirConditioner', 'Switch']}, 'Main_Siren': {'category': 'Siren', 'tags': ['Main', 'Siren']}}"
  },
  {
