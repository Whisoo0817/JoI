    "connected_devices": "{'GuestRoom_Motion': {'category': 'MotionSensor', 'tags': ['GuestRoom', 'MotionSensor']}, 'GuestRoom_AC': {'category': ['AirConditioner', 'Switch'], 'tags': ['GuestRoom', 'AirConditioner', 'Switch']}}"
  },
  {
